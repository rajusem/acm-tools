# Plan Feature Epics — default configuration
# These values are used as defaults by the /plan-feature-epics skill.
# Edit to change defaults; the skill will still ask for confirmation.

# Jira site (used as cloudId in MCP calls)
JIRA_SITE=stage-redhat.atlassian.net

# Project for non-ACM epics (e.g., OBSINTA)
EPIC_PROJECT=OBSINTA

# ACM epic component
ACM_COMPONENT=Observability

# Label prefix for all epics (appended with feature slug)
DEFAULT_LABEL_PREFIX=obsint-analytics

# Default activity type for all epics
ACTIVITY_TYPE=Product / Portfolio Work
