    verify_perses_dashboards "true" "false" || ((errors++)) || true

    CURRENT_MODE="mcoa"

    if [[ $errors -gt 0 ]]; then
        PHASE_FAIL_REASON="$errors assertion(s) failed"
        return 1
    fi
    return 0
}

