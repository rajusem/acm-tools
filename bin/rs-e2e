#!/bin/bash
# =============================================================================
# rs-e2e — End-to-end validation of right-sizing resource lifecycle
# =============================================================================
#
# Usage:
#   rs-e2e [options] [mco|mcoa]
#   rs-e2e --skip-uninstall          # Run phases 0-4a only
#   rs-e2e --mode-switch             # Include mode switching tests (phases 5-12, 15-16)
#   rs-e2e --build mco               # Build, push, and apply MCO image first
#   rs-e2e --phases 0-3,5,13-16      # Run specific phases (ranges OK)
#
# Phases (grouped by mode to minimize switches):
#
#   Group 1: MCO-mode tests
#   0    Pre-flight checks
#   1    Baseline resource verification
#   2a   Disable namespace RS only
#   2b   Swap features (ns on, virt off)
#   2c   Disable both features
#   2d   Re-enable both features
#   3    Spoke PrometheusRule validation
#   4    ConfigMap propagation (MCO)
#   4a   ConfigMap coexistence (MCO+MCOA)
#
#   Group 2: MCOA-mode tests (1 mode switch)
#   5    MCO -> MCOA switch            (--mode-switch)
#   6    SpecHash freshness            (--mode-switch)
#   7    ConfigMap predicate side-effect (--mode-switch)
#   8    Placement filter              (--mode-switch)
#   9a   Disable namespace RS (MCOA)   (--mode-switch)
#   9b   Swap features (MCOA)          (--mode-switch)
#   9c   Disable both (MCOA)           (--mode-switch)
#   9d   Re-enable both (MCOA)         (--mode-switch)
#   10   ConfigMap propagation (MCOA)  (--mode-switch)
#
#   Group 3: Mode round-trip tests
#   11   MCOA -> MCO switch            (--mode-switch)
#   12   Version mismatch              (--mode-switch)
#
#   Group 4: Destructive tests (MCO deletion/reinstall)
#   13   Uninstall cleanup (MCO mode)
#   14   Uninstall cleanup (MCOA mode)
#   15   MCOA uninstall + reinstall    (--mode-switch)
#   16   Mode switch after reinstall   (--mode-switch)
# =============================================================================

set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/../lib/common.sh"

: "${TIMEOUT_E2E_RECONCILE:=90}"
: "${TIMEOUT_E2E_MODE_SWITCH:=60}"

# =============================================================================
# Global State
# =============================================================================

CURRENT_MODE=""
FORCE_MODE=""
INITIAL_SPEC_HASHES=""
MW_PR_COUNT=0
RS_BINDING_TEST_NS="rs-binding-test"

SKIP_UNINSTALL=false
MODE_SWITCH=false
BUILD_TARGET=""
IMAGE_OVERRIDE_ONLY=false
SELECTED_PHASES=""
AUTO_CONFIRM=false
SKIP_PERSES_CHECK=false
CAPTURED_COO_VERSION=""
CAPTURED_PERSES_IMAGE=""

RESULT_IDS=()
RESULT_NAMES=()
RESULT_STATUSES=()
RESULT_NOTES=()
RESULT_DURATIONS=()
TOTAL_PASS=0
TOTAL_FAIL=0
TOTAL_SKIP=0
PHASE_FAIL_REASON=""
PHASE_SKIP_REASON=""
E2E_START_TIME=0

# =============================================================================
# CLI
# =============================================================================

usage() {
    cat <<EOF
Usage: $(basename "$0") [options] [mco|mcoa]

Options:
  --skip-uninstall       Run phases 0-4a only (no MCO deletion)
  --mode-switch          Include phases 5-12, 15-16 (mode switching tests)
  --build mco|mcoa|both  Build, push, and apply custom images before tests
  --image-override       Apply existing image-override.json (no build)
  --phases PHASES        Run specific phases (comma-separated, ranges OK: 0-3,5,9a)
  --skip-perses-check    Skip COO/Perses dashboard verification
  --yes                  Auto-confirm destructive phases (no prompts)
  -h, --help             Show this help

Positional:
  mco|mcoa               Force testing a specific mode (default: auto-detect)

Examples:
  $(basename "$0") --skip-uninstall
  $(basename "$0") --mode-switch
  $(basename "$0") --build mco --skip-uninstall
  $(basename "$0") --phases 0-3,5,13-16
  $(basename "$0") --mode-switch --yes    # Full run, no prompts
EOF
}

parse_args() {
    while [[ $# -gt 0 ]]; do
        case "$1" in
            --skip-uninstall) SKIP_UNINSTALL=true; shift ;;
            --mode-switch)    MODE_SWITCH=true; shift ;;
            --build)
                BUILD_TARGET="${2:-}"
                [[ -z "$BUILD_TARGET" ]] && { log_error "--build requires mco|mcoa|both"; exit 1; }
                shift 2 ;;
            --image-override) IMAGE_OVERRIDE_ONLY=true; shift ;;
            --skip-perses-check) SKIP_PERSES_CHECK=true; shift ;;
            --yes|-y)         AUTO_CONFIRM=true; shift ;;
            --phases)
                SELECTED_PHASES="${2:-}"
                [[ -z "$SELECTED_PHASES" ]] && { log_error "--phases requires comma-separated list"; exit 1; }
                shift 2 ;;
            -h|--help) usage; exit 0 ;;
            mco|mcoa)  FORCE_MODE="$1"; shift ;;
            *) log_error "Unknown option: $1"; usage; exit 1 ;;
        esac
    done

    if [[ -z "$SELECTED_PHASES" ]]; then
        if [[ "$SKIP_UNINSTALL" == "true" ]]; then
            SELECTED_PHASES="0,1,2a,2b,2c,2d,3,4a"
        elif [[ "$MODE_SWITCH" == "false" ]]; then
            SELECTED_PHASES="0,1,2a,2b,2c,2d,3,4,4a,13,14"
        fi
    fi

    if [[ -n "$SELECTED_PHASES" ]]; then
        SELECTED_PHASES=$(expand_phase_ranges "$SELECTED_PHASES")
    fi
}

# =============================================================================
# Result Tracking
# =============================================================================

format_duration() {
    local secs="$1"
    if [[ $secs -ge 60 ]]; then
        printf "%dm%02ds" $((secs / 60)) $((secs % 60))
    else
        printf "%ds" "$secs"
    fi
}

record_result() {
    local id="$1" name="$2" status="$3" notes="${4:-}" duration="${5:-0}"
    RESULT_IDS+=("$id")
    RESULT_NAMES+=("$name")
    RESULT_STATUSES+=("$status")
    RESULT_NOTES+=("$notes")
    RESULT_DURATIONS+=("$duration")

    local dur_str
    dur_str=$(format_duration "$duration")
    case "$status" in
        PASS) ((TOTAL_PASS++)) || true; log_success "Phase $id: PASS ($dur_str)" ;;
        FAIL) ((TOTAL_FAIL++)) || true; log_error "Phase $id: FAIL ($dur_str) — $notes" ;;
        SKIP) ((TOTAL_SKIP++)) || true; log_warn "Phase $id: SKIP — $notes" ;;
    esac
}

expand_phase_ranges() {
    local input="$1"
    local result=""
    local IFS=','
    for token in $input; do
        if [[ "$token" =~ ^([0-9]+)-([0-9]+)$ ]]; then
            local start="${BASH_REMATCH[1]}" end="${BASH_REMATCH[2]}"
            for ((i=start; i<=end; i++)); do
                result="${result:+$result,}$i"
            done
        else
            result="${result:+$result,}$token"
        fi
    done
    echo "$result"
}

phase_selected() {
    local id="$1"
    [[ -z "$SELECTED_PHASES" ]] && return 0
    echo ",$SELECTED_PHASES," | grep ",$id," >/dev/null && return 0
    if [[ "$id" =~ ^([0-9]+)[a-z]$ ]]; then
        local prefix="${BASH_REMATCH[1]}"
        echo ",$SELECTED_PHASES," | grep ",$prefix," >/dev/null && return 0
    fi
    return 1
}

run_phase() {
    local id="$1" name="$2" fn="$3"

    if ! phase_selected "$id"; then
        record_result "$id" "$name" "SKIP" "not selected" 0
        return 0
    fi

    echo ""
    log_step "Phase $id: $name"
    print_separator

    PHASE_FAIL_REASON=""
    PHASE_SKIP_REASON=""

    local phase_start=$SECONDS
    set +e
    "$fn"
    local rc=$?
    set -e
    local phase_duration=$((SECONDS - phase_start))

    if [[ $rc -eq 0 ]]; then
        record_result "$id" "$name" "PASS" "" "$phase_duration"
    elif [[ $rc -eq 2 ]]; then
        record_result "$id" "$name" "SKIP" "${PHASE_SKIP_REASON:-skipped}" "$phase_duration"
    else
        record_result "$id" "$name" "FAIL" "${PHASE_FAIL_REASON:-unknown}" "$phase_duration"
    fi
}

# =============================================================================
# Utility Helpers
# =============================================================================

e2e_confirm() {
    if [[ "$AUTO_CONFIRM" == "true" ]]; then
        log_info "Auto-confirmed: $1"
        return 0
    fi
    confirm "$@"
}

assert_exists() {
    local type="$1" name="$2" namespace="${3:-}"
    if resource_exists "$type" "$name" "$namespace"; then
        log_success "  $type/$name exists"
        return 0
    else
        log_error "  $type/$name NOT FOUND"
        return 1
    fi
}

assert_not_exists() {
    local type="$1" name="$2" namespace="${3:-}"
    if resource_exists "$type" "$name" "$namespace"; then
        log_error "  $type/$name still EXISTS"
        return 1
    else
        log_success "  $type/$name absent"
        return 0
    fi
}

not_resource_exists() {
    ! resource_exists "$@"
}

wait_for_reconcile() {
    local seconds="${1:-$TIMEOUT_E2E_RECONCILE}"
    local reason="${2:-Waiting for controller reconciliation}"
    wait_with_message "$seconds" "$reason"
}

wait_until() {
    local max_wait="$1" interval="$2" desc="$3"
    shift 3
    local elapsed=0
    while [[ $elapsed -lt $max_wait ]]; do
        if "$@" 2>/dev/null; then
            printf "\r%-80s\r" " " >&2
            return 0
        fi
        printf "\r  ${BLUE}%s (%ds/%ds)...${NC}  " "$desc" "$elapsed" "$max_wait" >&2
        sleep "$interval"
        elapsed=$((elapsed + interval))
    done
    printf "\r%-80s\r" " " >&2
    return 1
}

adc_not_mco_mode() {
    local actual
    actual=$($KUBE_CLI get addondeploymentconfig "$MCOA_NAME" -n "$OBS_NAMESPACE" \
        -o jsonpath='{.spec.customizedVariables[?(@.name=="platformNamespaceRightSizing")].value}' 2>/dev/null || echo "")
    [[ -n "$actual" && "$actual" != "disabled" ]]
}

adc_mco_mode() {
    local actual
    actual=$($KUBE_CLI get addondeploymentconfig "$MCOA_NAME" -n "$OBS_NAMESPACE" \
        -o jsonpath='{.spec.customizedVariables[?(@.name=="platformNamespaceRightSizing")].value}' 2>/dev/null || echo "")
    [[ "$actual" == "disabled" ]]
}

# --- Perses Dashboard Constants ---
RS_NS_DASHBOARD="acm-rs-namespace-overview"
RS_VM_DASHBOARDS=("acm-rightsizing-openshift-virtualization" "acm-rightsizing-vm-overestimation" "acm-rightsizing-vm-underestimation")
TIMEOUT_PERSES_DASHBOARD="${TIMEOUT_PERSES_DASHBOARD:-300}"

perses_dashboard_exists() {
    $KUBE_CLI get persesdashboard "$1" -n "$ANALYTICS_NAMESPACE" &>/dev/null
}

verify_perses_dashboards() {
    local ns_enabled="$1" virt_enabled="$2"
    local errors=0

    if [[ "$SKIP_PERSES_CHECK" == "true" ]]; then
        log_info "  Perses dashboard check skipped (--skip-perses-check)"
        return 0
    fi

    if [[ "$CURRENT_MODE" != "mcoa" ]]; then
        return 0
    fi

    log_substep "Checking COO installation"
    if ! check_coo_installed; then
        log_info "  COO not yet installed, waiting up to ${TIMEOUT_COO_INSTALL}s..."
        if ! wait_until "$TIMEOUT_COO_INSTALL" 10 "COO installation" check_coo_installed; then
            log_error "  COO not installed after ${TIMEOUT_COO_INSTALL}s (use --skip-perses-check to skip)"
            return 1
        fi
    fi
    log_success "  COO installed"

    if [[ -z "$CAPTURED_COO_VERSION" ]]; then
        CAPTURED_COO_VERSION=$($KUBE_CLI get csv -n openshift-operators --no-headers 2>/dev/null | \
            awk '/^cluster-observability-operator/{sub(/cluster-observability-operator\./,"",$1); print $1; exit}')
        local coo_ns="openshift-cluster-observability-operator"
        CAPTURED_PERSES_IMAGE=$($KUBE_CLI get pods -n "$coo_ns" --no-headers \
            -o custom-columns="NAME:.metadata.name,IMAGE:.spec.containers[0].image" 2>/dev/null | \
            awk '/^perses-/{print $2; exit}')
    fi

    log_substep "Waiting for Perses dashboards to converge"
    if [[ "$ns_enabled" == "true" ]]; then
        wait_until "$TIMEOUT_PERSES_DASHBOARD" 5 "namespace RS dashboard" \
            perses_dashboard_exists "$RS_NS_DASHBOARD" || true
    else
        wait_until "$TIMEOUT_PERSES_DASHBOARD" 5 "namespace dashboard deletion" \
            not_resource_exists persesdashboard "$RS_NS_DASHBOARD" "$ANALYTICS_NAMESPACE" || true
    fi
    if [[ "$virt_enabled" == "true" ]]; then
        wait_until "$TIMEOUT_PERSES_DASHBOARD" 5 "virt RS dashboard" \
            perses_dashboard_exists "${RS_VM_DASHBOARDS[0]}" || true
    else
        wait_until "$TIMEOUT_PERSES_DASHBOARD" 5 "virt dashboard deletion" \
            not_resource_exists persesdashboard "${RS_VM_DASHBOARDS[0]}" "$ANALYTICS_NAMESPACE" || true
    fi

    if [[ "$ns_enabled" == "true" ]]; then
        if perses_dashboard_exists "$RS_NS_DASHBOARD"; then
            log_success "  persesdashboard/$RS_NS_DASHBOARD exists"
        else
            log_error "  persesdashboard/$RS_NS_DASHBOARD NOT FOUND"
            ((errors++)) || true
        fi
    else
        if perses_dashboard_exists "$RS_NS_DASHBOARD"; then
            log_error "  persesdashboard/$RS_NS_DASHBOARD still EXISTS (namespace RS disabled)"
            ((errors++)) || true
        else
            log_success "  persesdashboard/$RS_NS_DASHBOARD absent (namespace RS disabled)"
        fi
    fi

    for db in "${RS_VM_DASHBOARDS[@]}"; do
        if [[ "$virt_enabled" == "true" ]]; then
            if perses_dashboard_exists "$db"; then
                log_success "  persesdashboard/$db exists"
            else
                log_error "  persesdashboard/$db NOT FOUND"
                ((errors++)) || true
            fi
        else
            if perses_dashboard_exists "$db"; then
                log_error "  persesdashboard/$db still EXISTS (virt RS disabled)"
                ((errors++)) || true
            else
                log_success "  persesdashboard/$db absent (virt RS disabled)"
            fi
        fi
    done

    return $errors
}

verify_no_perses_dashboards() {
    local errors=0

    if [[ "$SKIP_PERSES_CHECK" == "true" ]]; then
        return 0
    fi
    if [[ "$CURRENT_MODE" != "mcoa" && "$1" != "uninstall" ]]; then
        return 0
    fi

    log_substep "Checking RS Perses dashboards absent"

    for db in "$RS_NS_DASHBOARD" "${RS_VM_DASHBOARDS[@]}"; do
        if perses_dashboard_exists "$db"; then
            wait_until "$TIMEOUT_PERSES_DASHBOARD" 5 "$db deletion" \
                not_resource_exists persesdashboard "$db" "$ANALYTICS_NAMESPACE" || true
        fi
    done

    for db in "$RS_NS_DASHBOARD" "${RS_VM_DASHBOARDS[@]}"; do
        if perses_dashboard_exists "$db"; then
            log_error "  persesdashboard/$db still EXISTS"
            ((errors++)) || true
        else
            log_success "  persesdashboard/$db absent"
        fi
    done

    return $errors
}

mco_placements_ready() {
    resource_exists placement rs-placement "$GLOBAL_SET_NAMESPACE" && \
    resource_exists placement rs-virt-placement "$GLOBAL_SET_NAMESPACE"
}

mw_namespace_cluster_count() {
    local count=0
    local mc_list
    mc_list=$($KUBE_CLI get managedcluster -o jsonpath='{.items[*].metadata.name}' 2>/dev/null || echo "")
    for mc in $mc_list; do
        for mw in $($KUBE_CLI get manifestwork -n "$mc" -o name 2>/dev/null | grep "$MCOA_MW_PATTERN" || true); do
            local has_ns_pr
            has_ns_pr=$($KUBE_CLI get "$mw" -n "$mc" -o json 2>/dev/null | \
                jq '[.spec.workload.manifests[]? | select(.kind=="PrometheusRule") | select(.metadata.name | test("acm-rs-namespace"))] | length' \
                2>/dev/null || echo 0)
            if [[ "$has_ns_pr" -gt 0 ]]; then
                ((count++))
            fi
        done
    done
    echo "$count"
}

rs_defaults_populated() {
    local val
    val=$(get_resource_field mco "$MCO_NAME" "" \
        '{.spec.capabilities.platform.analytics.namespaceRightSizingRecommendation.enabled}' 2>/dev/null || echo "")
    [[ "$val" == "true" ]]
}

policy_contains() {
    local name="$1" namespace="$2" pattern="$3"
    $KUBE_CLI get policy "$name" -n "$namespace" -o json 2>/dev/null | grep "$pattern" >/dev/null 2>&1
}

mw_has_rs_prometheusrules() {
    manifestwork_contains "acm-rs"
}

manifestwork_contains() {
    local pattern="$1"
    local mc_list
    mc_list=$($KUBE_CLI get managedcluster -o jsonpath='{.items[*].metadata.name}' 2>/dev/null || echo "")
    for mc in $mc_list; do
        for mw in $($KUBE_CLI get manifestwork -n "$mc" -o name 2>/dev/null | grep "$MCOA_MW_PATTERN" || true); do
            if $KUBE_CLI get "$mw" -n "$mc" -o json 2>/dev/null | grep "$pattern" >/dev/null 2>&1; then
                return 0
            fi
        done
    done
    return 1
}

cleanup_stuck_mcoa_mw() {
    local cleaned=false
    local mw_list
    mw_list=$($KUBE_CLI get manifestwork -n local-cluster \
        -o jsonpath='{range .items[*]}{.metadata.name}{"\t"}{.metadata.deletionTimestamp}{"\n"}{end}' \
        2>/dev/null || echo "")

    while IFS=$'\t' read -r mw_name deletion_ts; do
        [[ -z "$mw_name" || -z "$deletion_ts" ]] && continue
        [[ "$mw_name" != *"$MCOA_MW_PATTERN"* ]] && continue
        log_warn "  Removing finalizers from stuck ManifestWork: $mw_name (deleting since $deletion_ts)"
        kube_retry $KUBE_CLI patch manifestwork "$mw_name" -n local-cluster \
            --type=merge -p '{"metadata":{"finalizers":[]}}' 2>/dev/null || true
        cleaned=true
    done <<< "$mw_list"

    if [[ "$cleaned" == "true" ]]; then
        sleep 5
        if $KUBE_CLI get manifestwork -n local-cluster -o name 2>/dev/null | grep "$MCOA_MW_PATTERN" >/dev/null 2>&1; then
            log_warn "  Some MCOA ManifestWorks still present after cleanup"
        else
            log_success "  Stuck ManifestWork(s) cleaned up"
        fi
    fi
}

get_current_mode() {
    local annotation
    annotation=$(get_resource_field mco "$MCO_NAME" "" \
        "{.metadata.annotations.${RS_ANNOTATION//./\\.}}" || echo "")
    if [[ -n "$annotation" ]]; then
        echo "mcoa"
    else
        echo "mco"
    fi
}

patch_rs_features() {
    local ns_enabled="$1" virt_enabled="$2"
    kube_retry $KUBE_CLI patch mco "$MCO_NAME" --type=merge -p "{
        \"spec\": {
            \"capabilities\": {
                \"platform\": {
                    \"analytics\": {
                        \"namespaceRightSizingRecommendation\": {\"enabled\": $ns_enabled},
                        \"virtualizationRightSizingRecommendation\": {\"enabled\": $virt_enabled}
                    }
                }
            }
        }
    }"
}

patch_rs_namespace_binding() {
    local ns_binding="$1" virt_binding="$2"
    kube_retry $KUBE_CLI patch mco "$MCO_NAME" --type=merge -p "{
        \"spec\": {
            \"capabilities\": {
                \"platform\": {
                    \"analytics\": {
                        \"namespaceRightSizingRecommendation\": {\"namespaceBinding\": \"$ns_binding\"},
                        \"virtualizationRightSizingRecommendation\": {\"namespaceBinding\": \"$virt_binding\"}
                    }
                }
            }
        }
    }"
}

ensure_mode() {
    local target="$1"
    local current
    current=$(get_current_mode)
    if [[ "$current" == "$target" ]]; then
        CURRENT_MODE="$target"
        return 0
    fi
    log_substep "Switching to $target mode (precondition)"
    if [[ "$target" == "mcoa" ]]; then
        $KUBE_CLI annotate mco "$MCO_NAME" "$RS_ANNOTATION=true" --overwrite
        wait_until "$TIMEOUT_E2E_MODE_SWITCH" 5 "MCOA reconciliation" \
            adc_not_mco_mode || true
        log_substep "Waiting for MCOA to auto-detect ADC change"
        if ! wait_until 60 5 "ManifestWork auto-generation" mw_has_rs_prometheusrules; then
            log_warn "MCOA did not auto-reconcile after ADC change — restarting as fallback"
            kube_retry $KUBE_CLI rollout restart deployment/$MCOA_DEPLOY \
                -n "$OBS_NAMESPACE" 2>/dev/null || true
            $KUBE_CLI rollout status deployment/$MCOA_DEPLOY \
                -n "$OBS_NAMESPACE" --timeout="${TIMEOUT_ROLLOUT}s" 2>/dev/null || true
            wait_for_reconcile 30 "Waiting for ManifestWork generation"
        fi
    else
        $KUBE_CLI annotate mco "$MCO_NAME" "$RS_ANNOTATION-" --overwrite 2>/dev/null || true
        wait_until "$TIMEOUT_E2E_MODE_SWITCH" 5 "MCO reconciliation" \
            mco_placements_ready || true
        sleep 20
        wait_until 30 5 "placement stabilization" mco_placements_ready || true
    fi
    CURRENT_MODE="$target"
}

ensure_mco_installed() {
    if resource_exists mco "$MCO_NAME"; then
        local ready
        ready=$(get_resource_field mco "$MCO_NAME" "" \
            '{.status.conditions[?(@.type=="Ready")].status}' || echo "")
        if [[ "$ready" == "True" ]]; then
            return 0
        fi
        log_substep "MCO exists but not Ready, waiting..."
        local elapsed=0
        while [[ $elapsed -lt $TIMEOUT_MCO_READY ]]; do
            ready=$(get_resource_field mco "$MCO_NAME" "" \
                '{.status.conditions[?(@.type=="Ready")].status}' || echo "")
            if [[ "$ready" == "True" ]]; then
                log_success "MCO is Ready"
                return 0
            fi
            printf "\r  ${BLUE}Waiting for MCO Ready (%ds/%ds)...${NC}  " "$elapsed" "$TIMEOUT_MCO_READY" >&2
            sleep 10
            elapsed=$((elapsed + 10))
        done
        printf "\r%-80s\r" " " >&2
        log_error "MCO not Ready after ${TIMEOUT_MCO_READY}s"
        return 1
    fi

    log_substep "MCO not installed, running setup-observability install"
    "$SCRIPT_DIR/setup-observability" install --force-cleanup-mw
}

# =============================================================================
# ADC & Resource Verification
# =============================================================================

verify_adc_state() {
    local expected_ns="$1" expected_virt="$2"
    local errors=0

    # In MCO mode, MCO syncs "disabled" to ADC so MCOA does not deploy RS via ManifestWork
    if [[ "$CURRENT_MODE" == "mco" ]]; then
        expected_ns="disabled"
        expected_virt="disabled"
    fi

    local adc_json
    adc_json=$($KUBE_CLI get addondeploymentconfig "$MCOA_NAME" \
        -n "$OBS_NAMESPACE" -o json 2>/dev/null || echo "")

    if [[ -z "$adc_json" ]]; then
        if [[ "$CURRENT_MODE" == "mcoa" ]]; then
            log_error "  ADC not found (expected in MCOA mode)"
            return 1
        fi
        return 0
    fi

    local actual_ns
    actual_ns=$(echo "$adc_json" | jq -r \
        '.spec.customizedVariables[]? | select(.name=="platformNamespaceRightSizing") | .value' \
        2>/dev/null || echo "")
    local actual_virt
    actual_virt=$(echo "$adc_json" | jq -r \
        '.spec.customizedVariables[]? | select(.name=="platformVirtualizationRightSizing") | .value' \
        2>/dev/null || echo "")

    if [[ "$actual_ns" != "$expected_ns" ]]; then
        log_error "  ADC namespace RS: '$actual_ns' (expected '$expected_ns')"
        ((errors++)) || true
    else
        log_success "  ADC namespace RS: $actual_ns"
    fi

    if [[ "$actual_virt" != "$expected_virt" ]]; then
        log_error "  ADC virt RS: '$actual_virt' (expected '$expected_virt')"
        ((errors++)) || true
    else
        log_success "  ADC virt RS: $actual_virt"
    fi

    return $errors
}

verify_adc_delegation() {
    local expected="$1"
    local actual
    actual=$($KUBE_CLI get addondeploymentconfig "$MCOA_NAME" \
        -n "$OBS_NAMESPACE" \
        -o jsonpath='{.spec.customizedVariables[?(@.name=="rightSizingDelegated")].value}' \
        2>/dev/null || echo "")
    if [[ "$actual" != "$expected" ]]; then
        log_error "  ADC rightSizingDelegated: '$actual' (expected '$expected')"
        return 1
    fi
    log_success "  ADC rightSizingDelegated: $actual"
    return 0
}

count_mw_prometheusrules() {
    local expect_zero="${1:-false}"
    MW_PR_COUNT=0
    MW_PR_ERRORS=0
    local mc_list
    mc_list=$($KUBE_CLI get managedcluster -o jsonpath='{.items[*].metadata.name}' 2>/dev/null || echo "")

    for mc in $mc_list; do
        local count=0
        for mw in $($KUBE_CLI get manifestwork -n "$mc" -o name 2>/dev/null | grep "$MCOA_MW_PATTERN" || true); do
            local mw_json
            mw_json=$($KUBE_CLI get "$mw" -n "$mc" -o json 2>/dev/null || echo "{}")
            local deleting
            deleting=$(echo "$mw_json" | jq -r '.metadata.deletionTimestamp // empty' 2>/dev/null)
            if [[ -n "$deleting" ]]; then
                if [[ "$expect_zero" == "true" ]]; then
                    log_info "    $mc: ManifestWork terminating (deletionTimestamp=$deleting)"
                else
                    log_error "    $mc: ManifestWork stuck terminating (deletionTimestamp=$deleting)"
                    ((MW_PR_ERRORS++)) || true
                fi
                continue
            fi
            local c
            c=$(echo "$mw_json" | \
                jq '[.spec.workload.manifests[]? | select(.kind=="PrometheusRule") | select(.metadata.name | test("acm-rs"))] | length' \
                2>/dev/null || echo 0)
            count=$((count + c))
        done
        MW_PR_COUNT=$((MW_PR_COUNT + count))
        if [[ $count -gt 0 ]]; then
            log_success "    $mc: $count RS PrometheusRule(s)"
        elif [[ "$expect_zero" == "true" ]]; then
            log_success "    $mc: 0 RS PrometheusRules (clean)"
        else
            log_error "    $mc: 0 RS PrometheusRules"
            ((MW_PR_ERRORS++)) || true
        fi
    done
    return $MW_PR_ERRORS
}

verify_all_rs_resources_exist() {
    local mode="$1"
    local errors=0

    if [[ "$mode" == "mco" ]]; then
        assert_exists placement rs-placement "$GLOBAL_SET_NAMESPACE" || ((errors++)) || true
        assert_exists placement rs-virt-placement "$GLOBAL_SET_NAMESPACE" || ((errors++)) || true
        assert_exists policy rs-prom-rules-policy "$GLOBAL_SET_NAMESPACE" || ((errors++)) || true
        assert_exists policy rs-virt-prom-rules-policy "$GLOBAL_SET_NAMESPACE" || ((errors++)) || true
        assert_exists placementbinding rs-policyset-binding "$GLOBAL_SET_NAMESPACE" || ((errors++)) || true
        assert_exists placementbinding rs-virt-policyset-binding "$GLOBAL_SET_NAMESPACE" || ((errors++)) || true
    fi

    assert_exists configmap rs-namespace-config "$OBS_NAMESPACE" || ((errors++)) || true
    assert_exists configmap rs-virt-config "$OBS_NAMESPACE" || ((errors++)) || true

    if [[ "$mode" == "mcoa" ]]; then
        log_substep "Checking ManifestWork PrometheusRules"
        count_mw_prometheusrules || ((errors += MW_PR_ERRORS)) || true
        if [[ $MW_PR_COUNT -eq 0 && $MW_PR_ERRORS -eq 0 ]]; then
            log_error "  ManifestWorks: 0 RS PrometheusRules (expected > 0)"
            ((errors++)) || true
        elif [[ $MW_PR_COUNT -gt 0 ]]; then
            log_success "  ManifestWorks: $MW_PR_COUNT total RS PrometheusRule(s)"
        fi
    fi

    return $errors
}

verify_all_rs_resources_deleted() {
    local mode="$1"
    local errors=0

    if [[ "$mode" == "mco" || "$mode" == "uninstall" ]]; then
        assert_not_exists placement rs-placement "$GLOBAL_SET_NAMESPACE" || ((errors++)) || true
        assert_not_exists placement rs-virt-placement "$GLOBAL_SET_NAMESPACE" || ((errors++)) || true
    fi

    assert_not_exists configmap rs-namespace-config "$OBS_NAMESPACE" || ((errors++)) || true
    assert_not_exists configmap rs-virt-config "$OBS_NAMESPACE" || ((errors++)) || true

    if [[ "$mode" == "mco" ]]; then
        assert_not_exists policy rs-prom-rules-policy "$GLOBAL_SET_NAMESPACE" || ((errors++)) || true
        assert_not_exists policy rs-virt-prom-rules-policy "$GLOBAL_SET_NAMESPACE" || ((errors++)) || true
        assert_not_exists placementbinding rs-policyset-binding "$GLOBAL_SET_NAMESPACE" || ((errors++)) || true
        assert_not_exists placementbinding rs-virt-policyset-binding "$GLOBAL_SET_NAMESPACE" || ((errors++)) || true
    fi

    if [[ "$mode" == "mcoa" || "$mode" == "uninstall" ]]; then
        log_substep "Checking ManifestWork PrometheusRules"
        count_mw_prometheusrules "true"
        if [[ $MW_PR_COUNT -gt 0 ]]; then
            log_error "  ManifestWorks: $MW_PR_COUNT RS PrometheusRule(s) remain"
            ((errors++)) || true
        fi
    fi

    return $errors
}

verify_spec_hashes_populated() {
    local mc_list
    mc_list=$($KUBE_CLI get managedcluster -o jsonpath='{.items[*].metadata.name}' 2>/dev/null || echo "")
    local errors=0
    for mc in $mc_list; do
        local hash
        hash=$($KUBE_CLI get managedclusteraddon "$MCOA_NAME" -n "$mc" \
            -o jsonpath='{.status.configReferences[0].desiredConfig.specHash}' 2>/dev/null || echo "")
        if [[ -n "$hash" ]]; then
            log_success "  $mc: specHash=$hash"
        else
            log_error "  $mc: specHash EMPTY"
            ((errors++)) || true
        fi
    done
    return $errors
}

get_all_spec_hashes() {
    local mc_list
    mc_list=$($KUBE_CLI get managedcluster -o jsonpath='{.items[*].metadata.name}' 2>/dev/null || echo "")
    local hashes=""
    for mc in $mc_list; do
        local hash
        hash=$($KUBE_CLI get managedclusteraddon "$MCOA_NAME" -n "$mc" \
            -o jsonpath='{.status.configReferences[0].desiredConfig.specHash}' 2>/dev/null || echo "EMPTY")
        log_info "    $mc: $hash" >&2
        hashes="${hashes:+$hashes|}$hash"
    done
    echo "$hashes"
}

# =============================================================================
# Pre-phase: Image Build & Deploy
# =============================================================================

prephase_build() {
    local target="$BUILD_TARGET"

    log_step "Pre-phase: Custom Image Build & Deploy"
    print_separator

    local override_json="$SCRIPT_DIR/../image-override.json"

    if [[ ! -f "$override_json" ]]; then
        log_error "image-override.json not found: $override_json"
        return 1
    fi
    if ! jq empty "$override_json" 2>/dev/null; then
        log_error "Invalid JSON in image-override.json"
        return 1
    fi
    if [[ -z "$CONTAINER_ENGINE" ]]; then
        log_error "No container engine found (podman or docker required)"
        return 1
    fi

    if [[ "$target" == "mco" || "$target" == "both" ]]; then
        local current_tag
        current_tag=$(jq -r '.[] | select(.["image-key"]=="multicluster_observability_operator") | .["image-tag"]' "$override_json")
        local num="${current_tag#v}"
        if ! [[ "$num" =~ ^[0-9]+$ ]]; then
            log_error "Cannot auto-increment MCO tag '$current_tag' — expected v<number>"
            return 1
        fi
        local new_tag="v$((num + 1))"
        log_info "MCO tag: $current_tag -> $new_tag"

        if [[ ! -d "$MCO_REPO_DIR" ]]; then
            log_error "MCO repo not found: $MCO_REPO_DIR"
            log_info "Set MCO_REPO_DIR in config.sh or environment"
            return 1
        fi

        local full_tag="$ACM_TOOLS_REGISTRY/$MCO_IMAGE_NAME:$new_tag"
        log_substep "Building $full_tag"
        $CONTAINER_ENGINE build --platform "$BUILD_PLATFORM" --no-cache \
            -t "$full_tag" -f "$MCO_REPO_DIR/$MCO_DOCKERFILE" "$MCO_REPO_DIR"

        log_substep "Pushing $full_tag"
        $CONTAINER_ENGINE push "$full_tag"

        local tmp
        tmp=$(jq --arg tag "$new_tag" \
            '[.[] | if .["image-key"]=="multicluster_observability_operator" then .["image-tag"]=$tag else . end]' \
            "$override_json")
        echo "$tmp" > "$override_json"
    fi

    if [[ "$target" == "mcoa" || "$target" == "both" ]]; then
        local current_tag
        current_tag=$(jq -r '.[] | select(.["image-key"]=="multicluster_observability_addon") | .["image-tag"]' "$override_json")
        local num="${current_tag#v}"
        if ! [[ "$num" =~ ^[0-9]+$ ]]; then
            log_error "Cannot auto-increment MCOA tag '$current_tag' — expected v<number>"
            return 1
        fi
        local new_tag="v$((num + 1))"
        log_info "MCOA tag: $current_tag -> $new_tag"

        if [[ ! -d "$MCOA_REPO_DIR" ]]; then
            log_error "MCOA repo not found: $MCOA_REPO_DIR"
            log_info "Set MCOA_REPO_DIR in config.sh or environment"
            return 1
        fi

        local full_tag="$ACM_TOOLS_REGISTRY/$MCOA_IMAGE_NAME:$new_tag"
        log_substep "Building $full_tag"
        $CONTAINER_ENGINE build --platform "$BUILD_PLATFORM" --no-cache \
            -t "$full_tag" -f "$MCOA_REPO_DIR/$MCOA_DOCKERFILE" "$MCOA_REPO_DIR"

        log_substep "Pushing $full_tag"
        $CONTAINER_ENGINE push "$full_tag"

        local tmp
        tmp=$(jq --arg tag "$new_tag" \
            '[.[] | if .["image-key"]=="multicluster_observability_addon" then .["image-tag"]=$tag else . end]' \
            "$override_json")
        echo "$tmp" > "$override_json"
    fi

    log_substep "Applying image overrides"
    IMAGE_OVERRIDE_ONLY=true
    prephase_image_override
    IMAGE_OVERRIDE_ONLY=false

    log_success "Pre-phase complete"
}

prephase_image_override() {
    log_step "Pre-phase: Apply Image Override"
    print_separator

    local override_json="$SCRIPT_DIR/../image-override.json"
    if [[ ! -f "$override_json" ]]; then
        log_error "image-override.json not found"
        return 1
    fi

    local expected_mco expected_mcoa
    expected_mco=$(jq -r '.[] | select(.["image-key"]=="multicluster_observability_operator") | "\(.["image-remote"])/\(.["image-name"]):\(.["image-tag"])"' "$override_json" 2>/dev/null || echo "")
    expected_mcoa=$(jq -r '.[] | select(.["image-key"]=="multicluster_observability_addon") | "\(.["image-remote"])/\(.["image-name"]):\(.["image-tag"])"' "$override_json" 2>/dev/null || echo "")

    "$SCRIPT_DIR/image-override" apply

    # Also patch mch-image-manifest so MCO uses the correct MCOA image
    # (MCH in Pending state won't propagate ConfigMap-based overrides)
    if [[ -n "$expected_mcoa" ]]; then
        local manifest_cm
        manifest_cm=$($KUBE_CLI get configmap -n "$ACM_NAMESPACE" --no-headers 2>/dev/null | \
            awk '/^mch-image-manifest/{print $1}' | tail -1)
        if [[ -n "$manifest_cm" ]]; then
            log_substep "Patching $manifest_cm with MCOA image"
            kube_retry $KUBE_CLI patch configmap "$manifest_cm" -n "$ACM_NAMESPACE" --type merge \
                -p "{\"data\":{\"multicluster_observability_addon\":\"$expected_mcoa\"}}"
        fi
    fi

    # Patch MCO deployment directly if image doesn't match
    if [[ -n "$expected_mco" ]]; then
        local current_mco
        current_mco=$($KUBE_CLI get pod -n "$ACM_NAMESPACE" \
            -l name=multicluster-observability-operator \
            -o jsonpath='{.items[0].spec.containers[0].image}' 2>/dev/null || echo "")
        if [[ "$current_mco" != "$expected_mco" ]]; then
            log_substep "Patching MCO deployment with $expected_mco"
            kube_retry $KUBE_CLI set image deployment/multicluster-observability-operator \
                multicluster-observability-operator="$expected_mco" \
                -n "$ACM_NAMESPACE"
        fi
    fi

    # Wait for MCO pod to run the expected image
    if [[ -n "$expected_mco" ]]; then
        log_substep "Waiting for MCO pod to run expected image"
        mco_pod_has_image() {
            local actual
            actual=$($KUBE_CLI get pod -n "$ACM_NAMESPACE" \
                -l name=multicluster-observability-operator \
                -o jsonpath='{.items[0].spec.containers[0].image}' 2>/dev/null || echo "")
            [[ "$actual" == "$1" ]]
        }
        if ! wait_until 120 10 "Waiting for MCO image" \
            mco_pod_has_image "$expected_mco"; then
            log_error "MCO pod did not pick up $expected_mco within 120s"
            PHASE_FAIL_REASON="MCO image override not applied"
            return 1
        fi
    fi

    log_substep "Verifying pod images"
    local mco_image mcoa_image
    mco_image=$($KUBE_CLI get pod -n "$ACM_NAMESPACE" \
        -l name=multicluster-observability-operator \
        -o jsonpath='{.items[0].spec.containers[0].image}' 2>/dev/null || echo "unknown")
    log_info "  MCO operator: $mco_image"
    if [[ -n "$expected_mco" && "$mco_image" != "$expected_mco" ]]; then
        log_error "  Expected: $expected_mco"
        return 1
    fi

    mcoa_image=$($KUBE_CLI get pod -n "$OBS_NAMESPACE" \
        -l app=multicluster-observability-addon-manager \
        -o jsonpath='{.items[0].spec.containers[0].image}' 2>/dev/null || echo "not running")
    log_info "  MCOA addon:   $mcoa_image"

    log_success "Image override applied and verified"
}

# =============================================================================
# Phase 0: Pre-flight
# =============================================================================

phase_0() {
    log_substep "Checking cluster connectivity"
    if ! $KUBE_CLI cluster-info &>/dev/null; then
        PHASE_FAIL_REASON="Cluster unreachable"
        return 1
    fi
    log_success "  Cluster reachable"

    log_substep "Checking ACM installation"
    if ! $KUBE_CLI get mch -A --no-headers 2>/dev/null | grep -v "^$" >/dev/null; then
        PHASE_FAIL_REASON="ACM not installed — run bin/install-custom-acm"
        return 1
    fi
    log_success "  ACM installed"

    log_substep "Checking MCO installation"
    if ! resource_exists mco "$MCO_NAME"; then
        log_warn "  MCO not installed — installing via setup-observability"
        "$SCRIPT_DIR/setup-observability" install --force-cleanup-mw
        if ! resource_exists mco "$MCO_NAME"; then
            PHASE_FAIL_REASON="Failed to install MCO"
            return 1
        fi
    fi
    log_success "  MCO installed"

    log_substep "Checking MCO Ready status"
    local ready
    ready=$(get_resource_field mco "$MCO_NAME" "" \
        '{.status.conditions[?(@.type=="Ready")].status}' || echo "")
    if [[ "$ready" != "True" ]]; then
        log_warn "  MCO not Ready, waiting up to ${TIMEOUT_MCO_READY}s..."
        local elapsed=0
        while [[ $elapsed -lt $TIMEOUT_MCO_READY ]]; do
            ready=$(get_resource_field mco "$MCO_NAME" "" \
                '{.status.conditions[?(@.type=="Ready")].status}' || echo "")
            if [[ "$ready" == "True" ]]; then break; fi
            printf "\r  ${BLUE}Waiting for MCO Ready (%ds/%ds)...${NC}  " "$elapsed" "$TIMEOUT_MCO_READY" >&2
            sleep 10
            elapsed=$((elapsed + 10))
        done
        printf "\r%-80s\r" " " >&2
        if [[ "$ready" != "True" ]]; then
            PHASE_FAIL_REASON="MCO not Ready after ${TIMEOUT_MCO_READY}s"
            return 1
        fi
    fi
    log_success "  MCO Ready"

    log_substep "Checking managed clusters"
    local mc_count
    mc_count=$($KUBE_CLI get managedcluster --no-headers 2>/dev/null | wc -l | tr -d ' ')
    if [[ "$mc_count" -eq 0 ]]; then
        PHASE_FAIL_REASON="No managed clusters found"
        return 1
    else
        local mc_names
        mc_names=$($KUBE_CLI get managedcluster -o jsonpath='{.items[*].metadata.name}' 2>/dev/null || echo "")
        log_success "  $mc_count managed cluster(s): $mc_names"
    fi

    log_substep "Checking for orphaned RS resources"
    local orphans=0
    for rname in rs-placement rs-virt-placement; do
        if resource_exists placement "$rname" "$GLOBAL_SET_NAMESPACE"; then
            log_info "  Found placement/$rname (will be managed by MCO)"
            ((orphans++)) || true
        fi
    done
    if [[ $orphans -eq 0 ]]; then
        log_success "  No orphaned RS resources"
    fi

    log_substep "Checking current images"
    local mco_image
    mco_image=$($KUBE_CLI get pod -n "$ACM_NAMESPACE" \
        -l name=multicluster-observability-operator \
        -o jsonpath='{.items[0].spec.containers[0].image}' 2>/dev/null || echo "unknown")
    log_info "  MCO operator: $mco_image"

    log_substep "Checking for stale IsMCOTerminating flag"
    local terminating_logs
    terminating_logs=$($KUBE_CLI logs deploy/multicluster-observability-operator \
        -n "$ACM_NAMESPACE" --tail=20 2>/dev/null | \
        grep "MCO is terminating, skip reconcile" || true)
    if [[ -n "$terminating_logs" ]]; then
        log_warn "  Stale IsMCOTerminating flag — restarting operator"
        kube_retry $KUBE_CLI rollout restart deploy/multicluster-observability-operator -n "$ACM_NAMESPACE"
        kube_retry $KUBE_CLI rollout status deploy/multicluster-observability-operator \
            -n "$ACM_NAMESPACE" --timeout="${TIMEOUT_ROLLOUT}s"
        wait_for_reconcile 30 "Waiting for operator restart"
    else
        log_success "  No stale IsMCOTerminating flag"
    fi

    log_substep "Checking local-cluster status"
    local lc_available
    lc_available=$($KUBE_CLI get managedcluster local-cluster \
        -o jsonpath='{.status.conditions[?(@.type=="ManagedClusterConditionAvailable")].status}' 2>/dev/null || echo "")
    if [[ "$lc_available" == "True" ]]; then
        log_success "  local-cluster: Available"
    elif [[ -n "$lc_available" ]]; then
        log_error "  local-cluster: Available=$lc_available"
        PHASE_FAIL_REASON="local-cluster not available"
        return 1
    fi

    log_substep "Checking RS auto-defaults"
    local ns_enabled
    ns_enabled=$(get_resource_field mco "$MCO_NAME" "" \
        '{.spec.capabilities.platform.analytics.namespaceRightSizingRecommendation.enabled}' || echo "")
    if [[ -z "$ns_enabled" ]]; then
        log_info "  RS features not in MCO spec — waiting for auto-defaults"
        wait_until 90 5 "RS auto-defaults" rs_defaults_populated || true
        ns_enabled=$(get_resource_field mco "$MCO_NAME" "" \
            '{.spec.capabilities.platform.analytics.namespaceRightSizingRecommendation.enabled}' || echo "")
    fi
    if [[ "$ns_enabled" == "true" ]]; then
        log_success "  RS auto-defaults populated"
    else
        log_info "  RS features will be enabled in Phase 1"
    fi

    return 0
}

# =============================================================================
# Phase 1: Baseline
# =============================================================================

phase_1() {
    local errors=0

    CURRENT_MODE=$(get_current_mode)
    log_info "  Detected mode: $CURRENT_MODE"

    if [[ -n "$FORCE_MODE" && "$FORCE_MODE" != "$CURRENT_MODE" ]]; then
        log_substep "Forcing $FORCE_MODE mode"
        ensure_mode "$FORCE_MODE" || { PHASE_FAIL_REASON="Failed to switch to $FORCE_MODE mode"; return 1; }
        CURRENT_MODE="$FORCE_MODE"
    fi

    log_substep "Ensuring both RS features enabled"
    patch_rs_features true true

    if [[ "$CURRENT_MODE" == "mco" ]]; then
        wait_until "$TIMEOUT_E2E_RECONCILE" 5 "RS resources creation" \
            resource_exists placement rs-placement "$GLOBAL_SET_NAMESPACE" || true
    else
        wait_until "$TIMEOUT_E2E_RECONCILE" 5 "RS resources creation" \
            resource_exists configmap rs-namespace-config "$OBS_NAMESPACE" || true
    fi

    log_substep "Running rs-status"
    "$SCRIPT_DIR/rs-status" --hub-only 2>/dev/null || true

    log_substep "Verifying all RS resources"
    verify_all_rs_resources_exist "$CURRENT_MODE" || ((errors++)) || true

    if [[ $errors -gt 0 ]]; then
        PHASE_FAIL_REASON="RS resource verification failed — see errors above"
        return 1
    fi
    return 0
}

# =============================================================================
# Phase 2: Feature Toggle Tests
# =============================================================================

phase_2a() {
    local errors=0

    ensure_mco_installed || { PHASE_FAIL_REASON="MCO not installed or not ready"; return 1; }
    ensure_mode mco || { PHASE_FAIL_REASON="Failed to switch to MCO mode"; return 1; }

    log_substep "Disabling namespace RS only"
    patch_rs_features false true

    wait_until "$TIMEOUT_E2E_RECONCILE" 5 "namespace resource cleanup" \
        not_resource_exists placement rs-placement "$GLOBAL_SET_NAMESPACE" || true

    log_substep "Verifying namespace resources deleted"
    assert_not_exists placement rs-placement "$GLOBAL_SET_NAMESPACE" || ((errors++)) || true
    assert_not_exists policy rs-prom-rules-policy "$GLOBAL_SET_NAMESPACE" || ((errors++)) || true
    assert_not_exists placementbinding rs-policyset-binding "$GLOBAL_SET_NAMESPACE" || ((errors++)) || true
    assert_not_exists configmap rs-namespace-config "$OBS_NAMESPACE" || ((errors++)) || true

    log_substep "Verifying virt resources retained"
    assert_exists placement rs-virt-placement "$GLOBAL_SET_NAMESPACE" || ((errors++)) || true
    assert_exists policy rs-virt-prom-rules-policy "$GLOBAL_SET_NAMESPACE" || ((errors++)) || true
    assert_exists placementbinding rs-virt-policyset-binding "$GLOBAL_SET_NAMESPACE" || ((errors++)) || true
    assert_exists configmap rs-virt-config "$OBS_NAMESPACE" || ((errors++)) || true

    if [[ $errors -gt 0 ]]; then
        PHASE_FAIL_REASON="Feature toggle verification failed — see errors above"
        return 1
    fi
    return 0
}

phase_2b() {
    local errors=0

    ensure_mco_installed || { PHASE_FAIL_REASON="MCO not installed or not ready"; return 1; }
    ensure_mode mco || { PHASE_FAIL_REASON="Failed to switch to MCO mode"; return 1; }

    log_substep "Swapping features: namespace on, virtualization off"
    patch_rs_features true false

    wait_until "$TIMEOUT_E2E_RECONCILE" 5 "feature swap reconciliation" \
        resource_exists placement rs-placement "$GLOBAL_SET_NAMESPACE" || true
    wait_until "$TIMEOUT_E2E_RECONCILE" 5 "virt resource cleanup" \
        not_resource_exists placement rs-virt-placement "$GLOBAL_SET_NAMESPACE" || true

    log_substep "Verifying namespace resources restored"
    assert_exists placement rs-placement "$GLOBAL_SET_NAMESPACE" || ((errors++)) || true
    assert_exists policy rs-prom-rules-policy "$GLOBAL_SET_NAMESPACE" || ((errors++)) || true
    assert_exists placementbinding rs-policyset-binding "$GLOBAL_SET_NAMESPACE" || ((errors++)) || true
    assert_exists configmap rs-namespace-config "$OBS_NAMESPACE" || ((errors++)) || true

    log_substep "Verifying virt resources deleted"
    assert_not_exists placement rs-virt-placement "$GLOBAL_SET_NAMESPACE" || ((errors++)) || true
    assert_not_exists policy rs-virt-prom-rules-policy "$GLOBAL_SET_NAMESPACE" || ((errors++)) || true
    assert_not_exists placementbinding rs-virt-policyset-binding "$GLOBAL_SET_NAMESPACE" || ((errors++)) || true
    assert_not_exists configmap rs-virt-config "$OBS_NAMESPACE" || ((errors++)) || true

    if [[ $errors -gt 0 ]]; then
        PHASE_FAIL_REASON="Feature toggle verification failed — see errors above"
        return 1
    fi
    return 0
}

phase_2c() {
    local errors=0

    ensure_mco_installed || { PHASE_FAIL_REASON="MCO not installed or not ready"; return 1; }
    ensure_mode mco || { PHASE_FAIL_REASON="Failed to switch to MCO mode"; return 1; }

    log_substep "Disabling both RS features"
    patch_rs_features false false

    wait_until "$TIMEOUT_E2E_RECONCILE" 5 "full resource cleanup" \
        not_resource_exists placement rs-placement "$GLOBAL_SET_NAMESPACE" || true

    log_substep "Verifying all RS resources deleted"
    verify_all_rs_resources_deleted "mco" || ((errors++)) || true

    if [[ $errors -gt 0 ]]; then
        PHASE_FAIL_REASON="$errors assertion(s) failed"
        return 1
    fi
    return 0
}

phase_2d() {
    local errors=0

    ensure_mco_installed || { PHASE_FAIL_REASON="MCO not installed or not ready"; return 1; }
    ensure_mode mco || { PHASE_FAIL_REASON="Failed to switch to MCO mode"; return 1; }

    log_substep "Re-enabling both RS features"
    patch_rs_features true true

    wait_until "$TIMEOUT_E2E_RECONCILE" 5 "resource restoration" \
        resource_exists placement rs-placement "$GLOBAL_SET_NAMESPACE" || true
    wait_until "$TIMEOUT_E2E_RECONCILE" 5 "virt resource restoration" \
        resource_exists placement rs-virt-placement "$GLOBAL_SET_NAMESPACE" || true

    log_substep "Verifying all RS resources restored"
    verify_all_rs_resources_exist "mco" || ((errors++)) || true

    if [[ $errors -gt 0 ]]; then
        PHASE_FAIL_REASON="RS resource verification failed — see errors above"
        return 1
    fi
    return 0
}

# =============================================================================
# Phase 2e: NamespaceBinding change (MCO mode)
# =============================================================================

phase_2e() {
    local errors=0

    ensure_mco_installed || { PHASE_FAIL_REASON="MCO not installed or not ready"; return 1; }
    ensure_mode mco || { PHASE_FAIL_REASON="Failed to switch to MCO mode"; return 1; }

    log_substep "Ensuring both RS features enabled"
    patch_rs_features true true

    wait_until "$TIMEOUT_E2E_RECONCILE" 5 "baseline resource creation" \
        resource_exists placement rs-placement "$GLOBAL_SET_NAMESPACE" || true

    log_substep "Creating test namespace $RS_BINDING_TEST_NS"
    kube_retry $KUBE_CLI create namespace "$RS_BINDING_TEST_NS" 2>/dev/null || true

    log_substep "Patching namespaceBinding to $RS_BINDING_TEST_NS"
    patch_rs_namespace_binding "$RS_BINDING_TEST_NS" "$RS_BINDING_TEST_NS"

    wait_until "$TIMEOUT_E2E_RECONCILE" 5 "resources in new namespace" \
        resource_exists placement rs-placement "$RS_BINDING_TEST_NS" || true
    wait_until "$TIMEOUT_E2E_RECONCILE" 5 "virt resources in new namespace" \
        resource_exists placement rs-virt-placement "$RS_BINDING_TEST_NS" || true

    log_substep "Verifying resources exist in $RS_BINDING_TEST_NS"
    assert_exists placement rs-placement "$RS_BINDING_TEST_NS" || ((errors++)) || true
    assert_exists placement rs-virt-placement "$RS_BINDING_TEST_NS" || ((errors++)) || true
    assert_exists policy rs-prom-rules-policy "$RS_BINDING_TEST_NS" || ((errors++)) || true
    assert_exists policy rs-virt-prom-rules-policy "$RS_BINDING_TEST_NS" || ((errors++)) || true
    assert_exists placementbinding rs-policyset-binding "$RS_BINDING_TEST_NS" || ((errors++)) || true
    assert_exists placementbinding rs-virt-policyset-binding "$RS_BINDING_TEST_NS" || ((errors++)) || true

    log_substep "Verifying resources cleaned up from $GLOBAL_SET_NAMESPACE"
    assert_not_exists placement rs-placement "$GLOBAL_SET_NAMESPACE" || ((errors++)) || true
    assert_not_exists placement rs-virt-placement "$GLOBAL_SET_NAMESPACE" || ((errors++)) || true
    assert_not_exists policy rs-prom-rules-policy "$GLOBAL_SET_NAMESPACE" || ((errors++)) || true
    assert_not_exists policy rs-virt-prom-rules-policy "$GLOBAL_SET_NAMESPACE" || ((errors++)) || true
    assert_not_exists placementbinding rs-policyset-binding "$GLOBAL_SET_NAMESPACE" || ((errors++)) || true
    assert_not_exists placementbinding rs-virt-policyset-binding "$GLOBAL_SET_NAMESPACE" || ((errors++)) || true

    log_substep "Verifying ConfigMaps unchanged in $OBS_NAMESPACE"
    assert_exists configmap rs-namespace-config "$OBS_NAMESPACE" || ((errors++)) || true
    assert_exists configmap rs-virt-config "$OBS_NAMESPACE" || ((errors++)) || true

    log_substep "Resetting namespaceBinding to default"
    patch_rs_namespace_binding "" ""

    wait_until "$TIMEOUT_E2E_RECONCILE" 5 "resources restored in default namespace" \
        resource_exists placement rs-placement "$GLOBAL_SET_NAMESPACE" || true
    wait_until "$TIMEOUT_E2E_RECONCILE" 5 "virt resources restored in default namespace" \
        resource_exists placement rs-virt-placement "$GLOBAL_SET_NAMESPACE" || true

    log_substep "Verifying resources restored in $GLOBAL_SET_NAMESPACE"
    assert_exists placement rs-placement "$GLOBAL_SET_NAMESPACE" || ((errors++)) || true
    assert_exists placement rs-virt-placement "$GLOBAL_SET_NAMESPACE" || ((errors++)) || true
    assert_exists policy rs-prom-rules-policy "$GLOBAL_SET_NAMESPACE" || ((errors++)) || true
    assert_exists policy rs-virt-prom-rules-policy "$GLOBAL_SET_NAMESPACE" || ((errors++)) || true

    log_substep "Verifying resources absent from $RS_BINDING_TEST_NS"
    assert_not_exists placement rs-placement "$RS_BINDING_TEST_NS" || ((errors++)) || true
    assert_not_exists placement rs-virt-placement "$RS_BINDING_TEST_NS" || ((errors++)) || true

    log_substep "Cleaning up test namespace"
    kube_retry $KUBE_CLI delete namespace "$RS_BINDING_TEST_NS" --ignore-not-found 2>/dev/null || true

    if [[ $errors -gt 0 ]]; then
        PHASE_FAIL_REASON="$errors assertion(s) failed during namespaceBinding change"
        return 1
    fi
    return 0
}

# =============================================================================
# Phase 3: Spoke Validation
# =============================================================================

phase_3() {
    local errors=0

    ensure_mco_installed || { PHASE_FAIL_REASON="MCO not installed or not ready"; return 1; }
    ensure_mode mco || { PHASE_FAIL_REASON="Failed to switch to MCO mode"; return 1; }

    if [[ "$CURRENT_MODE" == "mco" ]]; then
        log_substep "Waiting for Policy compliance (may need time after prior phases)"
        local compliant=false
        for i in $(seq 1 24); do
            local compliance
            compliance=$($KUBE_CLI get policy rs-prom-rules-policy -n "$GLOBAL_SET_NAMESPACE" \
                -o jsonpath='{.status.compliant}' 2>/dev/null || echo "")
            if [[ "$compliance" == "Compliant" ]]; then
                compliant=true
                break
            fi
            sleep 5
        done

        log_substep "Checking PlacementDecisions"
        local pd_clusters
        pd_clusters=$($KUBE_CLI get placementdecision -n "$GLOBAL_SET_NAMESPACE" \
            -l cluster.open-cluster-management.io/placement=rs-placement \
            -o jsonpath='{.items[*].status.decisions[*].clusterName}' 2>/dev/null || echo "")
        if [[ -n "$pd_clusters" ]]; then
            log_success "  PlacementDecision clusters: $pd_clusters"
        else
            log_error "  No clusters in PlacementDecision"
            ((errors++)) || true
        fi

        log_substep "Checking Policy compliance"
        if [[ "$compliant" == "true" ]]; then
            log_success "  Policy rs-prom-rules-policy: Compliant"
        else
            local compliance
            compliance=$($KUBE_CLI get policy rs-prom-rules-policy -n "$GLOBAL_SET_NAMESPACE" \
                -o jsonpath='{.status.compliant}' 2>/dev/null || echo "")
            log_error "  Policy rs-prom-rules-policy: ${compliance:-unknown}"
            ((errors++)) || true
        fi

    else
        log_substep "Checking ManifestWork PrometheusRules (MCOA mode)"
        count_mw_prometheusrules || ((errors += MW_PR_ERRORS)) || true
        if [[ $MW_PR_COUNT -gt 0 ]]; then
            log_success "  $MW_PR_COUNT total RS PrometheusRule(s) in ManifestWorks"
        elif [[ $MW_PR_ERRORS -eq 0 ]]; then
            log_error "  No RS PrometheusRules in ManifestWorks"
            ((errors++)) || true
        fi
    fi

    log_substep "Checking spoke PrometheusRules directly"
    local spoke_checked=false
    local -a spoke_contexts=()
    local managed_clusters
    managed_clusters=$($KUBE_CLI get managedcluster -o jsonpath='{.items[*].metadata.name}' 2>/dev/null || echo "")
    for ctx_name in "$NAMESPACE_SPOKE_CONTEXT" "$VM_SPOKE_CONTEXT"; do
        local cluster_name="$ctx_name"
        if [[ -n "$managed_clusters" ]] && ! echo "$managed_clusters" | tr ' ' '\n' | grep -x "$cluster_name" >/dev/null 2>&1; then
            continue
        fi
        spoke_contexts+=("$ctx_name")
    done
    if [[ ${#spoke_contexts[@]} -eq 0 ]]; then
        log_info "  No matching spoke contexts found among managed clusters: $managed_clusters"
    fi
    for ctx_name in "${spoke_contexts[@]}"; do
        log_info "  Checking spoke $ctx_name..." >&2
        if $KUBE_CLI --context="$ctx_name" cluster-info --request-timeout=10s &>/dev/null 2>&1; then
            local pr_count
            pr_count=$($KUBE_CLI --context="$ctx_name" get prometheusrule -n openshift-monitoring \
                --no-headers 2>/dev/null | grep -c -i "rs-\|acm-rs" || true)
            if [[ "$pr_count" -gt 0 ]]; then
                log_success "  Spoke $ctx_name: $pr_count RS PrometheusRule(s)"
            else
                log_error "  Spoke $ctx_name: 0 RS PrometheusRules"
                ((errors++)) || true
            fi
            spoke_checked=true
        else
            log_info "  Spoke $ctx_name: unreachable (skipped)"
        fi
    done
    if [[ "$spoke_checked" == "false" ]]; then
        log_info "  No spoke contexts reachable — hub-only validation sufficient"
    fi

    if [[ $errors -gt 0 ]]; then
        PHASE_FAIL_REASON="$errors check(s) failed"
        return 1
    fi
    return 0
}

# =============================================================================
# Phase 13-14: Uninstall Cleanup
# =============================================================================

phase_13() {
    if ! e2e_confirm "Phase 13 will DELETE the MCO CR (MCO mode). Continue?"; then
        PHASE_SKIP_REASON="user declined"
        return 2
    fi

    local errors=0

    ensure_mco_installed || { PHASE_FAIL_REASON="MCO not installed or not ready"; return 1; }
    ensure_mode mco || { PHASE_FAIL_REASON="Failed to switch to MCO mode"; return 1; }

    log_substep "Deleting MCO via setup-observability uninstall"
    echo "y" | "$SCRIPT_DIR/setup-observability" uninstall

    log_substep "Independently verifying RS resource cleanup"
    wait_until "$TIMEOUT_RS_CLEANUP" 5 "RS resource cleanup" \
        not_resource_exists placement rs-placement "$GLOBAL_SET_NAMESPACE" || true

    verify_all_rs_resources_deleted "mco" || ((errors++)) || true

    if [[ $errors -gt 0 ]]; then
        PHASE_FAIL_REASON="$errors resource(s) remain after uninstall"
        return 1
    fi
    return 0
}

phase_14() {
    if ! e2e_confirm "Phase 14 will reinstall MCO, switch to MCOA, then delete again. Continue?"; then
        PHASE_SKIP_REASON="user declined"
        return 2
    fi

    local errors=0

    if resource_exists mco "$MCO_NAME"; then
        log_substep "MCO still exists — deleting first"
        echo "y" | "$SCRIPT_DIR/setup-observability" uninstall
        wait_until "$TIMEOUT_RS_CLEANUP" 5 "MCO deletion" \
            not_resource_exists mco "$MCO_NAME" || true
    fi

    log_substep "Installing MCO"
    "$SCRIPT_DIR/setup-observability" install --force-cleanup-mw
    ensure_mco_installed || { PHASE_FAIL_REASON="MCO reinstall failed"; return 1; }

    log_substep "Enabling RS features"
    patch_rs_features true true
    wait_until "$TIMEOUT_E2E_RECONCILE" 5 "RS resource creation" \
        resource_exists placement rs-placement "$GLOBAL_SET_NAMESPACE" || true

    log_substep "Switching to MCOA mode"
    $KUBE_CLI annotate mco "$MCO_NAME" "$RS_ANNOTATION=true" --overwrite
    wait_until "$TIMEOUT_E2E_MODE_SWITCH" 5 "MCOA mode delegation" \
        adc_not_mco_mode || true
    log_substep "Waiting for MCOA to auto-detect ADC change"
    if ! wait_until 60 5 "ManifestWork auto-generation" mw_has_rs_prometheusrules; then
        log_warn "MCOA did not auto-reconcile after ADC change — restarting as fallback"
        kube_retry $KUBE_CLI rollout restart deployment/$MCOA_DEPLOY -n "$OBS_NAMESPACE" 2>/dev/null || true
        $KUBE_CLI rollout status deployment/$MCOA_DEPLOY \
            -n "$OBS_NAMESPACE" --timeout="${TIMEOUT_ROLLOUT}s" 2>/dev/null || true
        wait_for_reconcile 30 "Waiting for ManifestWork generation"
    fi

    log_substep "Verifying MCOA resources before deletion"
    verify_all_rs_resources_exist "mcoa" || ((errors++)) || true

    log_substep "Deleting MCO (MCOA mode)"
    echo "y" | "$SCRIPT_DIR/setup-observability" uninstall

    log_substep "Verifying RS resource cleanup"
    wait_until "$TIMEOUT_RS_CLEANUP" 5 "RS resource cleanup" \
        not_resource_exists configmap rs-namespace-config "$OBS_NAMESPACE" || true

    verify_all_rs_resources_deleted "uninstall" || ((errors++)) || true

    log_substep "Verifying MCOA-specific cleanup"
    assert_not_exists clustermanagementaddon "$MCOA_NAME" "" || ((errors++)) || true

    local mc_list
    mc_list=$($KUBE_CLI get managedcluster -o jsonpath='{.items[*].metadata.name}' 2>/dev/null || echo "")
    for mc in $mc_list; do
        if resource_exists managedclusteraddon "$MCOA_NAME" "$mc"; then
            log_error "  MCA $MCOA_NAME still exists in $mc"
            ((errors++)) || true
        fi
    done

    verify_no_perses_dashboards "uninstall" || ((errors++)) || true

    CURRENT_MODE=""

    if [[ $errors -gt 0 ]]; then
        PHASE_FAIL_REASON="$errors resource(s) remain after MCOA uninstall"
        return 1
    fi
    return 0
}

# =============================================================================
# Phase 5: MCO -> MCOA Switch, Phase 11: MCOA -> MCO Switch
# =============================================================================

phase_5() {
    if ! e2e_confirm "Phase 5 will switch to MCOA mode. Continue?"; then
        PHASE_SKIP_REASON="user declined"
        return 2
    fi

    local errors=0

    ensure_mco_installed || { PHASE_FAIL_REASON="MCO not installed or not ready"; return 1; }
    ensure_mode mco || { PHASE_FAIL_REASON="Failed to switch to MCO mode"; return 1; }

    log_substep "Cleaning up stuck ManifestWorks (local-cluster)"
    cleanup_stuck_mcoa_mw

    log_substep "Enabling both RS features"
    patch_rs_features true true
    wait_until "$TIMEOUT_E2E_RECONCILE" 5 "RS resource creation" \
        resource_exists policy rs-prom-rules-policy "$GLOBAL_SET_NAMESPACE" || true

    log_substep "Setting MCO CR annotation: right-sizing-capable=true"
    $KUBE_CLI annotate mco "$MCO_NAME" "$RS_ANNOTATION=true" --overwrite
    CURRENT_MODE="mcoa"

    wait_until "$TIMEOUT_E2E_MODE_SWITCH" 5 "mode switch reconciliation" \
        not_resource_exists policy rs-prom-rules-policy "$GLOBAL_SET_NAMESPACE" || true

    log_substep "Waiting for MCOA to auto-detect ADC change"
    if ! wait_until 60 5 "ManifestWork auto-generation" mw_has_rs_prometheusrules; then
        log_warn "MCOA did not auto-reconcile after ADC change — restarting as fallback"
        kube_retry $KUBE_CLI rollout restart deployment/$MCOA_DEPLOY -n "$OBS_NAMESPACE" 2>/dev/null || true
        $KUBE_CLI rollout status deployment/$MCOA_DEPLOY \
            -n "$OBS_NAMESPACE" --timeout="${TIMEOUT_ROLLOUT}s" 2>/dev/null || true
        wait_for_reconcile 30 "Waiting for ManifestWork generation"
    fi

    log_substep "Verifying MCO -> MCOA transition"
    assert_not_exists policy rs-prom-rules-policy "$GLOBAL_SET_NAMESPACE" || ((errors++)) || true
    assert_not_exists policy rs-virt-prom-rules-policy "$GLOBAL_SET_NAMESPACE" || ((errors++)) || true
    assert_not_exists placementbinding rs-policyset-binding "$GLOBAL_SET_NAMESPACE" || ((errors++)) || true
    assert_not_exists placementbinding rs-virt-policyset-binding "$GLOBAL_SET_NAMESPACE" || ((errors++)) || true

    assert_exists configmap rs-namespace-config "$OBS_NAMESPACE" || ((errors++)) || true
    assert_exists configmap rs-virt-config "$OBS_NAMESPACE" || ((errors++)) || true

    log_substep "Checking MCA specHash"
    verify_spec_hashes_populated || ((errors++)) || true

    log_substep "Checking ManifestWork PrometheusRules"
    count_mw_prometheusrules || ((errors += MW_PR_ERRORS)) || true
    if [[ $MW_PR_COUNT -eq 0 && $MW_PR_ERRORS -eq 0 ]]; then
        log_error "  ManifestWorks: 0 RS PrometheusRules"
        ((errors++)) || true
    elif [[ $MW_PR_COUNT -gt 0 ]]; then
        log_success "  ManifestWorks: $MW_PR_COUNT RS PrometheusRule(s)"
    fi

    log_substep "Checking ADC state"
    verify_adc_state "enabled" "enabled" || ((errors++)) || true

    log_substep "Checking Perses dashboards"
    verify_perses_dashboards "true" "true" || ((errors++)) || true

    if [[ $errors -gt 0 ]]; then
        PHASE_FAIL_REASON="$errors assertion(s) failed"
        return 1
    fi
    return 0
}

phase_11() {
    local errors=0

    ensure_mco_installed || { PHASE_FAIL_REASON="MCO not installed or not ready"; return 1; }
    ensure_mode mcoa || { PHASE_FAIL_REASON="Failed to switch to MCOA mode"; return 1; }

    log_substep "Removing MCO CR annotation"
    $KUBE_CLI annotate mco "$MCO_NAME" "$RS_ANNOTATION-" --overwrite 2>/dev/null || true

    wait_until "$TIMEOUT_E2E_MODE_SWITCH" 5 "MCO mode reconciliation" \
        mco_placements_ready || true

    # After placements first appear, the addon framework's InstallStrategy cleanup
    # may race and delete them. MCO's 10s requeue detects missing placements and
    # recreates them. Wait for that stabilization cycle to complete.
    log_substep "Waiting for placement stabilization after addon cleanup (20s)"
    sleep 20
    wait_until 30 5 "placement stabilization" mco_placements_ready || true

    log_substep "Verifying MCOA -> MCO transition"
    assert_exists policy rs-prom-rules-policy "$GLOBAL_SET_NAMESPACE" || ((errors++)) || true
    assert_exists policy rs-virt-prom-rules-policy "$GLOBAL_SET_NAMESPACE" || ((errors++)) || true
    assert_exists placementbinding rs-policyset-binding "$GLOBAL_SET_NAMESPACE" || ((errors++)) || true
    assert_exists placementbinding rs-virt-policyset-binding "$GLOBAL_SET_NAMESPACE" || ((errors++)) || true

    assert_exists placement rs-placement "$GLOBAL_SET_NAMESPACE" || ((errors++)) || true
    assert_exists placement rs-virt-placement "$GLOBAL_SET_NAMESPACE" || ((errors++)) || true

    log_substep "Checking ManifestWork PrometheusRules removed"
    count_mw_prometheusrules "true"
    if [[ $MW_PR_COUNT -gt 0 ]]; then
        log_error "  ManifestWorks: $MW_PR_COUNT RS PrometheusRule(s) remain"
        ((errors++)) || true
    fi

    CURRENT_MODE="mco"
    log_substep "Checking ADC state"
    verify_adc_state "disabled" "disabled" || ((errors++)) || true

    if [[ $errors -gt 0 ]]; then
        PHASE_FAIL_REASON="ADC not synced to disabled after MCOA->MCO switch"
        return 1
    fi
    return 0
}

# =============================================================================
# Phase 12: Version Mismatch
# =============================================================================

phase_12() {
    local errors=0

    ensure_mco_installed || { PHASE_FAIL_REASON="MCO not installed or not ready"; return 1; }
    ensure_mode mco || { PHASE_FAIL_REASON="Failed to switch to MCO mode"; return 1; }

    log_substep "Setting annotation with non-standard value: v99"
    $KUBE_CLI annotate mco "$MCO_NAME" "$RS_ANNOTATION=v99" --overwrite
    CURRENT_MODE="mcoa"

    wait_until "$TIMEOUT_E2E_MODE_SWITCH" 5 "delegation with v99 annotation" \
        adc_not_mco_mode || true

    log_substep "Verifying delegation occurs regardless of annotation value"
    assert_not_exists policy rs-prom-rules-policy "$GLOBAL_SET_NAMESPACE" || ((errors++)) || true
    assert_not_exists policy rs-virt-prom-rules-policy "$GLOBAL_SET_NAMESPACE" || ((errors++)) || true
    assert_exists configmap rs-namespace-config "$OBS_NAMESPACE" || ((errors++)) || true
    assert_exists configmap rs-virt-config "$OBS_NAMESPACE" || ((errors++)) || true

    verify_adc_state "enabled" "enabled" || ((errors++)) || true

    log_substep "Removing annotation (back to MCO mode)"
    $KUBE_CLI annotate mco "$MCO_NAME" "$RS_ANNOTATION-" --overwrite 2>/dev/null || true

    wait_until "$TIMEOUT_E2E_MODE_SWITCH" 5 "MCO mode restoration" \
        mco_placements_ready || true
    sleep 20
    wait_until 30 5 "placement stabilization" mco_placements_ready || true

    log_substep "Verifying MCO mode restored"
    assert_exists policy rs-prom-rules-policy "$GLOBAL_SET_NAMESPACE" || ((errors++)) || true
    assert_exists policy rs-virt-prom-rules-policy "$GLOBAL_SET_NAMESPACE" || ((errors++)) || true

    CURRENT_MODE="mco"

    if [[ $errors -gt 0 ]]; then
        PHASE_FAIL_REASON="$errors assertion(s) failed"
        return 1
    fi
    return 0
}

# =============================================================================
# Phase 6: SpecHash Freshness
# =============================================================================

phase_6() {
    local errors=0

    ensure_mco_installed || { PHASE_FAIL_REASON="MCO not installed or not ready"; return 1; }
    ensure_mode mcoa || { PHASE_FAIL_REASON="Failed to switch to MCOA mode"; return 1; }

    log_substep "Recording initial specHash values"
    INITIAL_SPEC_HASHES=$(get_all_spec_hashes)
    log_info "  Initial hashes: $INITIAL_SPEC_HASHES"

    if echo "$INITIAL_SPEC_HASHES" | grep "EMPTY" >/dev/null; then
        log_error "  Some specHash values are empty — cannot test freshness"
        PHASE_FAIL_REASON="Empty specHash values"
        return 1
    fi

    log_substep "Disabling virtualization RS to trigger ADC change"
    patch_rs_features true false
    if [[ "$CURRENT_MODE" == "mco" ]]; then
        wait_until "$TIMEOUT_E2E_MODE_SWITCH" 5 "virt RS disable" \
            not_resource_exists placement rs-virt-placement "$GLOBAL_SET_NAMESPACE" || true
    else
        wait_until "$TIMEOUT_E2E_MODE_SWITCH" 5 "virt RS disable" \
            not_resource_exists configmap rs-virt-config "$OBS_NAMESPACE" || true
    fi

    log_substep "Waiting for specHash to change"
    local new_hashes=""
    local hash_changed=false
    local elapsed=0
    local hash_timeout=60
    while (( elapsed < hash_timeout )); do
        new_hashes=$(get_all_spec_hashes)
        if [[ "$new_hashes" != "$INITIAL_SPEC_HASHES" ]] && ! echo "$new_hashes" | grep "EMPTY" >/dev/null; then
            hash_changed=true
            break
        fi
        sleep 5
        elapsed=$((elapsed + 5))
        log_info "  Waiting for specHash change (${elapsed}s/${hash_timeout}s)..." >&2
    done
    log_info "  New hashes: $new_hashes"

    if $hash_changed; then
        log_success "  SpecHash changed correctly"
    else
        log_error "  SpecHash did NOT change after ${hash_timeout}s"
        ((errors++)) || true
    fi

    log_substep "Re-enabling virtualization RS"
    patch_rs_features true true
    if [[ "$CURRENT_MODE" == "mco" ]]; then
        wait_until "$TIMEOUT_E2E_MODE_SWITCH" 5 "virt RS re-enable" \
            resource_exists placement rs-virt-placement "$GLOBAL_SET_NAMESPACE" || true
    else
        wait_until "$TIMEOUT_E2E_MODE_SWITCH" 5 "virt RS re-enable" \
            resource_exists configmap rs-virt-config "$OBS_NAMESPACE" || true
    fi

    log_substep "Waiting for specHash to restore"
    local restored_hashes=""
    local hash_restored=false
    elapsed=0
    while (( elapsed < hash_timeout )); do
        restored_hashes=$(get_all_spec_hashes)
        if [[ "$restored_hashes" == "$INITIAL_SPEC_HASHES" ]]; then
            hash_restored=true
            break
        fi
        sleep 5
        elapsed=$((elapsed + 5))
        log_info "  Waiting for specHash restore (${elapsed}s/${hash_timeout}s)..." >&2
    done
    log_info "  Restored hashes: $restored_hashes"

    if $hash_restored; then
        log_success "  SpecHash restored to original value"
    else
        log_error "  SpecHash differs from original after ${hash_timeout}s"
        ((errors++)) || true
    fi

    CURRENT_MODE="mcoa"

    if [[ $errors -gt 0 ]]; then
        PHASE_FAIL_REASON="$errors assertion(s) failed"
        return 1
    fi
    return 0
}

# =============================================================================
# Phase 7: ConfigMap Predicate Side-Effect
# =============================================================================

phase_7() {
    local errors=0

    ensure_mco_installed || { PHASE_FAIL_REASON="MCO not installed or not ready"; return 1; }
    ensure_mode mcoa || { PHASE_FAIL_REASON="Failed to switch to MCOA mode"; return 1; }

    log_substep "Verifying no Policies exist (MCOA mode baseline)"
    assert_not_exists policy rs-prom-rules-policy "$GLOBAL_SET_NAMESPACE" || {
        PHASE_FAIL_REASON="Policy already exists — test precondition not met"
        return 1
    }

    log_substep "Modifying RS ConfigMap (adding testKey)"
    local _json
    _json=$(kube_retry $KUBE_CLI get configmap rs-namespace-config -n "$OBS_NAMESPACE" -o json | \
        jq '.data.config = (.data.config // "{}" | fromjson | .testKey = "testValue" | tojson)')
    kube_apply_json "$_json"

    wait_for_reconcile "$TIMEOUT_E2E_RECONCILE" "Waiting for potential side-effect"

    log_substep "Verifying NO Policy created as side-effect"
    assert_not_exists policy rs-prom-rules-policy "$GLOBAL_SET_NAMESPACE" || ((errors++)) || true
    assert_not_exists placementbinding rs-policyset-binding "$GLOBAL_SET_NAMESPACE" || ((errors++)) || true

    log_substep "Reverting ConfigMap change"
    _json=$(kube_retry $KUBE_CLI get configmap rs-namespace-config -n "$OBS_NAMESPACE" -o json | \
        jq '.data.config = (.data.config | fromjson | del(.testKey) | tojson)')
    kube_apply_json "$_json"

    CURRENT_MODE="mcoa"

    if [[ $errors -gt 0 ]]; then
        PHASE_FAIL_REASON="ConfigMap change created Policy side-effect"
        return 1
    fi
    return 0
}

# =============================================================================
# Phase 8: Placement Filter
# =============================================================================

phase_8() {
    local errors=0

    ensure_mco_installed || { PHASE_FAIL_REASON="MCO not installed or not ready"; return 1; }
    ensure_mode mcoa || { PHASE_FAIL_REASON="Failed to switch to MCOA mode"; return 1; }

    local spoke_name
    spoke_name=$($KUBE_CLI get managedcluster \
        -o jsonpath='{.items[?(@.metadata.name!="local-cluster")].metadata.name}' 2>/dev/null | awk '{print $1}')

    if [[ -z "$spoke_name" ]]; then
        PHASE_SKIP_REASON="No non-local-cluster spoke available"
        return 2
    fi

    # MCOA uses in-memory predicate evaluation — no Placement CRs or PlacementDecisions.
    # Validate filtering via ManifestWork content: which clusters have namespace RS PRs.
    log_substep "Default placement — checking ManifestWork cluster count"
    local default_ns_count
    default_ns_count=$(mw_namespace_cluster_count)
    log_info "  Default: $default_ns_count cluster(s) with namespace RS PrometheusRules"

    # Label the spoke cluster so the in-memory predicate can select it
    log_substep "Labeling $spoke_name for placement filter"
    kube_retry $KUBE_CLI label managedcluster "$spoke_name" rs-e2e-filter=selected --overwrite

    log_substep "Applying placement filter to select only $spoke_name"
    # Update the placementConfiguration YAML key in rs-namespace-config.
    # MCOA reads this during Build() and evaluates predicates in-memory.
    local placement_yaml
    placement_yaml=$(cat <<'PLACEMENTEOF'
spec:
  predicates:
  - requiredclusterselector:
      labelselector:
        matchlabels:
          rs-e2e-filter: selected
  tolerations:
  - key: cluster.open-cluster-management.io/unreachable
    operator: Exists
  - key: cluster.open-cluster-management.io/unavailable
    operator: Exists
PLACEMENTEOF
)

    _json=$(kube_retry $KUBE_CLI get configmap rs-namespace-config -n "$OBS_NAMESPACE" -o json | \
        jq --arg pc "$placement_yaml" '.data.placementConfiguration = $pc')
    kube_apply_json "$_json"

    # Wait for MCOA to auto-detect ConfigMap change and regenerate ManifestWorks
    log_substep "Waiting for MCOA to auto-detect ConfigMap change"
    local auto_detected=false
    mw_filter_applied() { [[ "$(mw_namespace_cluster_count)" -le 1 ]]; }
    if wait_until 60 5 "auto-propagation of placement filter" mw_filter_applied; then
        auto_detected=true
        log_success "MCOA auto-detected ConfigMap change"
    else
        log_warn "MCOA did not auto-detect ConfigMap change (same limitation as phase 10)"
        log_substep "Restarting MCOA addon manager as fallback"
        kube_retry $KUBE_CLI rollout restart deployment/$MCOA_DEPLOY -n "$OBS_NAMESPACE" 2>/dev/null || true
        $KUBE_CLI rollout status deployment/$MCOA_DEPLOY \
            -n "$OBS_NAMESPACE" --timeout="${TIMEOUT_ROLLOUT}s" 2>/dev/null || true
        wait_for_reconcile 30 "Waiting for filtered ManifestWork generation"
    fi

    log_substep "Verifying namespace placement restricted"
    local filtered_ns_count
    filtered_ns_count=$(mw_namespace_cluster_count)

    if [[ "$filtered_ns_count" -le 1 ]]; then
        if [[ "$filtered_ns_count" -eq 0 ]]; then
            log_error "  Namespace filter: 0 clusters (filter did not match any label)"
            ((errors++)) || true
        else
            log_success "  Namespace filter: $filtered_ns_count cluster(s) (was $default_ns_count)"
        fi
    else
        log_error "  Namespace filter: expected <=1 cluster, got $filtered_ns_count (was $default_ns_count)"
        ((errors++)) || true
    fi

    log_substep "Verifying virt PrometheusRules unaffected"
    count_mw_prometheusrules || ((errors += MW_PR_ERRORS)) || true
    if [[ $MW_PR_COUNT -gt 0 ]]; then
        log_success "  Total RS PrometheusRules: $MW_PR_COUNT (virt unaffected)"
    elif [[ $MW_PR_ERRORS -eq 0 ]]; then
        log_error "  No RS PrometheusRules found"
        ((errors++)) || true
    fi

    log_substep "Resetting placement filter"
    local default_placement_yaml
    default_placement_yaml=$(cat <<'DEFAULTEOF'
spec:
  predicates: []
  tolerations:
  - key: cluster.open-cluster-management.io/unreachable
    operator: Exists
  - key: cluster.open-cluster-management.io/unavailable
    operator: Exists
DEFAULTEOF
)

    _json=$(kube_retry $KUBE_CLI get configmap rs-namespace-config -n "$OBS_NAMESPACE" -o json | \
        jq --arg pc "$default_placement_yaml" '.data.placementConfiguration = $pc')
    kube_apply_json "$_json"

    # Remove the test label
    kube_retry $KUBE_CLI label managedcluster "$spoke_name" rs-e2e-filter- --overwrite 2>/dev/null || true

    # Wait for MCOA to auto-detect reset
    log_substep "Waiting for MCOA to auto-detect placement reset"
    mw_filter_restored() { [[ "$(mw_namespace_cluster_count)" -ge "$default_ns_count" ]]; }
    if ! wait_until 60 5 "auto-propagation of placement reset" mw_filter_restored; then
        log_warn "MCOA did not auto-detect ConfigMap reset — restarting as fallback"
        kube_retry $KUBE_CLI rollout restart deployment/$MCOA_DEPLOY -n "$OBS_NAMESPACE" 2>/dev/null || true
        $KUBE_CLI rollout status deployment/$MCOA_DEPLOY \
            -n "$OBS_NAMESPACE" --timeout="${TIMEOUT_ROLLOUT}s" 2>/dev/null || true
        wait_for_reconcile 30 "Waiting for default ManifestWork generation"
    fi

    log_substep "Verifying default placement restored"
    local restored_ns_count
    restored_ns_count=$(mw_namespace_cluster_count)
    if [[ "$restored_ns_count" -ge "$default_ns_count" ]]; then
        log_success "  Default placement restored: $restored_ns_count cluster(s)"
    else
        log_error "  Placement not fully restored: $restored_ns_count (was $default_ns_count)"
        ((errors++)) || true
    fi

    CURRENT_MODE="mcoa"

    if [[ $errors -gt 0 ]]; then
        PHASE_FAIL_REASON="$errors assertion(s) failed"
        return 1
    fi
    return 0
}

# =============================================================================
# Phase 9: Both-Disabled MCOA
# =============================================================================

phase_9a() {
    local errors=0

    ensure_mco_installed || { PHASE_FAIL_REASON="MCO not installed or not ready"; return 1; }
    ensure_mode mcoa || { PHASE_FAIL_REASON="Failed to switch to MCOA mode"; return 1; }

    log_substep "Disabling namespace RS only (MCOA mode)"
