# =============================================================================
# Phase 9e: NamespaceBinding change (MCOA mode)
# =============================================================================

phase_9e() {
    local errors=0

    ensure_mco_installed || { PHASE_FAIL_REASON="MCO not installed or not ready"; return 1; }
    ensure_mode mcoa || { PHASE_FAIL_REASON="Failed to switch to MCOA mode"; return 1; }

    log_substep "Ensuring both RS features enabled"
    patch_rs_features true true

    wait_until "$TIMEOUT_E2E_RECONCILE" 5 "MCOA configmap creation" \
        resource_exists configmap rs-namespace-config "$OBS_NAMESPACE" || true

    log_substep "Creating test namespace $RS_BINDING_TEST_NS"
    kube_retry $KUBE_CLI create namespace "$RS_BINDING_TEST_NS" 2>/dev/null || true

    log_substep "Patching namespaceBinding to $RS_BINDING_TEST_NS"
    patch_rs_namespace_binding "$RS_BINDING_TEST_NS" "$RS_BINDING_TEST_NS"

    wait_for_reconcile 30 "MCO reconcile after binding change"

    log_substep "Verifying no Policies in $RS_BINDING_TEST_NS (MCOA mode)"
    assert_not_exists policy rs-prom-rules-policy "$RS_BINDING_TEST_NS" || ((errors++)) || true
    assert_not_exists policy rs-virt-prom-rules-policy "$RS_BINDING_TEST_NS" || ((errors++)) || true

    log_substep "Verifying no Policies in $GLOBAL_SET_NAMESPACE (MCOA mode)"
    assert_not_exists policy rs-prom-rules-policy "$GLOBAL_SET_NAMESPACE" || ((errors++)) || true
    assert_not_exists policy rs-virt-prom-rules-policy "$GLOBAL_SET_NAMESPACE" || ((errors++)) || true

    log_substep "Verifying ManifestWork PrometheusRules unaffected"
    count_mw_prometheusrules || true
    if [[ $MW_PR_COUNT -gt 0 ]]; then
        log_success "  ManifestWorks: $MW_PR_COUNT RS PrometheusRule(s) (unaffected)"
    else
        log_warn "  ManifestWorks: 0 RS PrometheusRules (MCOA may not have generated them — not a binding issue)"
    fi

    log_substep "Verifying ConfigMaps unchanged in $OBS_NAMESPACE"
    assert_exists configmap rs-namespace-config "$OBS_NAMESPACE" || ((errors++)) || true
    assert_exists configmap rs-virt-config "$OBS_NAMESPACE" || ((errors++)) || true

    log_substep "Resetting namespaceBinding to default"
    patch_rs_namespace_binding "" ""

    log_substep "Cleaning up test namespace"
    kube_retry $KUBE_CLI delete namespace "$RS_BINDING_TEST_NS" --ignore-not-found 2>/dev/null || true

    CURRENT_MODE="mcoa"

    if [[ $errors -gt 0 ]]; then
        PHASE_FAIL_REASON="$errors assertion(s) failed during MCOA namespaceBinding change"
        return 1
    fi
    return 0
}

# =============================================================================
# Phase 4 & 10: ConfigMap Propagation
# =============================================================================

phase_4() {
    local errors=0

    ensure_mco_installed || { PHASE_FAIL_REASON="MCO not installed or not ready"; return 1; }
    ensure_mode mco || { PHASE_FAIL_REASON="Failed to switch to MCO mode"; return 1; }

    log_substep "Modifying rs-namespace-config: recommendationPercentage 110 -> 120"
    # MCO stores prometheusRuleConfig as YAML; MCOA stores it as JSON.
    # Handle both: try JSON parse first, fall back to YAML gsub.
    local _json
    _json=$(kube_retry $KUBE_CLI get configmap rs-namespace-config -n "$OBS_NAMESPACE" -o json | \
        jq '.data.prometheusRuleConfig |= (. as $v | try ($v | fromjson | .recommendationPercentage = 120 | tojson) catch ($v | gsub("recommendationPercentage: 110"; "recommendationPercentage: 120")))')
    kube_apply_json "$_json"

    # MCO renders the percentage in PrometheusRule expr as "(120/100)".
    wait_until "$TIMEOUT_E2E_RECONCILE" 5 "Policy update" \
        policy_contains rs-prom-rules-policy "$GLOBAL_SET_NAMESPACE" "120/100" || true

    log_substep "Checking PrometheusRule in Policy contains updated percentage"
    local policy_json
    policy_json=$(kube_retry $KUBE_CLI get policy rs-prom-rules-policy -n "$GLOBAL_SET_NAMESPACE" -o json 2>/dev/null || echo "{}")
    if echo "$policy_json" | jq -e '.. | objects | select(.kind=="PrometheusRule") | .spec.groups[]?.rules[]?.expr | select(test("120/100"))' >/dev/null 2>&1; then
        log_success "  Policy PrometheusRule expr contains (120/100)"
    else
        log_error "  Policy PrometheusRule does not contain (120/100) in expr"
        ((errors++)) || true
    fi

    log_substep "Reverting: recommendationPercentage 120 -> 110"
    _json=$(kube_retry $KUBE_CLI get configmap rs-namespace-config -n "$OBS_NAMESPACE" -o json | \
        jq '.data.prometheusRuleConfig |= (. as $v | try ($v | fromjson | .recommendationPercentage = 110 | tojson) catch ($v | gsub("recommendationPercentage: 120"; "recommendationPercentage: 110")))')
    kube_apply_json "$_json"

    CURRENT_MODE="mco"

    if [[ $errors -gt 0 ]]; then
        PHASE_FAIL_REASON="ConfigMap change not propagated to Policy"
        return 1
    fi
    return 0
}

phase_10() {
    local errors=0

    ensure_mco_installed || { PHASE_FAIL_REASON="MCO not installed or not ready"; return 1; }
    ensure_mode mcoa || { PHASE_FAIL_REASON="Failed to switch to MCOA mode"; return 1; }

    log_substep "Modifying rs-namespace-config: recommendationPercentage 110 -> 120"
    # MCO stores prometheusRuleConfig as YAML; MCOA stores it as JSON.
    # Handle both: try JSON parse first, fall back to YAML gsub.
    local _json
    _json=$(kube_retry $KUBE_CLI get configmap rs-namespace-config -n "$OBS_NAMESPACE" -o json | \
        jq '.data.prometheusRuleConfig |= (. as $v | try ($v | fromjson | .recommendationPercentage = 120 | tojson) catch ($v | gsub("recommendationPercentage: 110"; "recommendationPercentage: 120")))')
    kube_apply_json "$_json"

    # MCOA Watcher watches RS ConfigMaps and calls addonManager.Trigger() for all clusters.
    # The percentage appears in PrometheusRule expr as "(120/100)".
    wait_until 120 5 "ManifestWork update" \
        manifestwork_contains "120/100" || true

    log_substep "Checking PrometheusRule in ManifestWork contains updated percentage"
    local found_120=false
    local mc_list
    mc_list=$(kube_retry $KUBE_CLI get managedcluster -o jsonpath='{.items[*].metadata.name}' 2>/dev/null || echo "")
    for mc in $mc_list; do
        for mw in $(kube_retry $KUBE_CLI get manifestwork -n "$mc" -o name 2>/dev/null | grep "$MCOA_MW_PATTERN" || true); do
            if kube_retry $KUBE_CLI get "$mw" -n "$mc" -o json 2>/dev/null | \
                jq -e '[.spec.workload.manifests[]? | select(.kind=="PrometheusRule") | .spec.groups[]?.rules[]?.expr | select(test("120/100"))] | length > 0' >/dev/null 2>&1; then
                found_120=true
                log_success "  $mc: PrometheusRule expr contains (120/100)"
                break 2
            fi
        done
    done
    if [[ "$found_120" == "false" ]]; then
        log_error "  No PrometheusRule in ManifestWorks contains (120/100)"
        ((errors++)) || true
    fi

    log_substep "Reverting: recommendationPercentage 120 -> 110"
    _json=$(kube_retry $KUBE_CLI get configmap rs-namespace-config -n "$OBS_NAMESPACE" -o json | \
        jq '.data.prometheusRuleConfig |= (. as $v | try ($v | fromjson | .recommendationPercentage = 110 | tojson) catch ($v | gsub("recommendationPercentage: 120"; "recommendationPercentage: 110")))')
    kube_apply_json "$_json"

    CURRENT_MODE="mcoa"

    if [[ $errors -gt 0 ]]; then
        PHASE_FAIL_REASON="ConfigMap change not propagated to ManifestWork"
        return 1
    fi
    return 0
}

# =============================================================================
# Phase 4a: ConfigMap Coexistence (MCO+MCOA)
# =============================================================================

phase_4a() {
    local errors=0

    ensure_mco_installed || { PHASE_FAIL_REASON="MCO not installed or not ready"; return 1; }
    ensure_mode mco || { PHASE_FAIL_REASON="Failed to ensure MCO mode"; return 1; }

    log_substep "Verifying RS ConfigMaps exist (baseline)"
    assert_exists configmap rs-namespace-config "$OBS_NAMESPACE" || { PHASE_FAIL_REASON="Baseline RS ConfigMaps missing"; return 1; }
    assert_exists configmap rs-virt-config "$OBS_NAMESPACE" || { PHASE_FAIL_REASON="Baseline RS ConfigMaps missing"; return 1; }

    log_substep "Enabling incident detection to trigger MCOA deployment"
    kube_retry $KUBE_CLI patch mco "$MCO_NAME" --type=merge -p '{
        "spec":{"capabilities":{"platform":{"analytics":{"incidentDetection":{"enabled":true}}}}}
    }'

    log_substep "Waiting for MCOA deployment"
    wait_until 120 10 "MCOA deployment" \
        $KUBE_CLI rollout status deployment/$MCOA_DEPLOY -n "$OBS_NAMESPACE" --timeout=5s || true

    if ! $KUBE_CLI get deployment "$MCOA_DEPLOY" -n "$OBS_NAMESPACE" &>/dev/null; then
        PHASE_FAIL_REASON="MCOA deployment not created after enabling incident detection"
        kube_retry $KUBE_CLI patch mco "$MCO_NAME" --type=merge -p '{
            "spec":{"capabilities":{"platform":{"analytics":{"incidentDetection":{"enabled":false}}}}}
        }'
        return 1
    fi
    log_success "  MCOA deployment ready"

    log_substep "Checking ADC delegation signal"
    wait_until 30 5 "ADC delegation sync" \
        verify_adc_delegation "false" || true
    verify_adc_delegation "false" || ((errors++)) || true

    log_substep "Verifying RS ConfigMaps survived MCOA deployment"
    assert_exists configmap rs-namespace-config "$OBS_NAMESPACE" || ((errors++)) || true
    assert_exists configmap rs-virt-config "$OBS_NAMESPACE" || ((errors++)) || true

    log_substep "Waiting 30s and re-checking ConfigMaps (catch delayed deletion)"
    sleep 30
    assert_exists configmap rs-namespace-config "$OBS_NAMESPACE" || ((errors++)) || true
    assert_exists configmap rs-virt-config "$OBS_NAMESPACE" || ((errors++)) || true

    log_substep "Verifying no RS ManifestWork PrometheusRules (MCO uses Policy)"
    count_mw_prometheusrules "true"
    if [[ $MW_PR_COUNT -gt 0 ]]; then
        log_error "  ManifestWorks: $MW_PR_COUNT RS PrometheusRule(s) — should be 0 in MCO mode"
        ((errors++)) || true
    else
        log_success "  ManifestWorks: 0 RS PrometheusRules (correct for MCO mode)"
    fi

    log_substep "Verifying no RS Perses dashboards (MCO mode)"
    for db in "$RS_NS_DASHBOARD" "${RS_VM_DASHBOARDS[@]}"; do
        if perses_dashboard_exists "$db"; then
            log_error "  persesdashboard/$db EXISTS — should not be created in MCO mode"
            ((errors++)) || true
        else
            log_success "  persesdashboard/$db absent (correct for MCO mode)"
        fi
    done

    log_substep "Reverting: disabling incident detection"
    kube_retry $KUBE_CLI patch mco "$MCO_NAME" --type=merge -p '{
        "spec":{"capabilities":{"platform":{"analytics":{"incidentDetection":{"enabled":false}}}}}
    }'
    wait_for_reconcile 30 "Waiting for MCO reconciliation after revert"

    if [[ $errors -gt 0 ]]; then
        PHASE_FAIL_REASON="MCOA leaked RS resources in MCO mode — delegation signal not working"
        return 1
    fi
    return 0
}

# =============================================================================
# Phase 15-16: MCO Reinstall After MCOA
# =============================================================================

phase_15() {
    if ! e2e_confirm "Phase 15 will delete MCO in MCOA mode and reinstall. Continue?"; then
        PHASE_SKIP_REASON="user declined"
        return 2
    fi

    local errors=0

    ensure_mco_installed || { PHASE_FAIL_REASON="MCO not installed or not ready"; return 1; }
    ensure_mode mcoa || { PHASE_FAIL_REASON="Failed to switch to MCOA mode"; return 1; }

    log_substep "Enabling both RS features"
    patch_rs_features true true
    wait_until "$TIMEOUT_E2E_RECONCILE" 5 "RS resource creation" \
        resource_exists configmap rs-namespace-config "$OBS_NAMESPACE" || true

    log_substep "Deleting MCO (MCOA mode)"
    echo "y" | "$SCRIPT_DIR/setup-observability" uninstall

    log_substep "Verifying RS cleanup"
    wait_until "$TIMEOUT_RS_CLEANUP" 5 "RS resource cleanup" \
        not_resource_exists configmap rs-namespace-config "$OBS_NAMESPACE" || true
    verify_all_rs_resources_deleted "uninstall" || ((errors++)) || true

    log_substep "Reinstalling MCO"
    "$SCRIPT_DIR/setup-observability" install --force-cleanup-mw
    ensure_mco_installed || { PHASE_FAIL_REASON="MCO reinstall failed"; return 1; }

    CURRENT_MODE=$(get_current_mode)
    log_info "  Post-reinstall mode: $CURRENT_MODE"

    if [[ "$CURRENT_MODE" != "mco" ]]; then
        log_error "  Expected MCO mode after reinstall, got: $CURRENT_MODE"
        ((errors++)) || true
    else
        log_success "  MCO starts in default MCO mode"
    fi

    log_substep "Waiting for RS auto-defaults"
    wait_until 90 5 "RS auto-defaults" rs_defaults_populated || true

    local ns_enabled
    ns_enabled=$(get_resource_field mco "$MCO_NAME" "" \
        '{.spec.capabilities.platform.analytics.namespaceRightSizingRecommendation.enabled}' || echo "")
    if [[ "$ns_enabled" == "true" ]]; then
        log_success "  RS features auto-enabled"
    else
        log_error "  RS features not auto-enabled after reinstall"
        ((errors++)) || true
        patch_rs_features true true
        wait_until "$TIMEOUT_E2E_RECONCILE" 5 "RS resource creation" \
            resource_exists placement rs-placement "$GLOBAL_SET_NAMESPACE" || true
    fi

    log_substep "Checking for stale IsMCOTerminating"
    local terminating
    terminating=$($KUBE_CLI logs deploy/multicluster-observability-operator \
        -n "$ACM_NAMESPACE" --tail=20 2>/dev/null | \
        grep "MCO is terminating, skip reconcile" || true)
    if [[ -n "$terminating" ]]; then
        log_error "  Stale IsMCOTerminating detected after reinstall"
        ((errors++)) || true
    else
        log_success "  No stale IsMCOTerminating flag"
    fi

    if [[ $errors -gt 0 ]]; then
        PHASE_FAIL_REASON="$errors issue(s) after reinstall"
        return 1
    fi
    return 0
}

phase_16() {
    local errors=0

    ensure_mco_installed || { PHASE_FAIL_REASON="MCO not installed or not ready"; return 1; }
    ensure_mode mco || { PHASE_FAIL_REASON="Failed to switch to MCO mode"; return 1; }

    log_substep "Switching to MCOA mode"
    $KUBE_CLI annotate mco "$MCO_NAME" "$RS_ANNOTATION=true" --overwrite
    CURRENT_MODE="mcoa"
    wait_until "$TIMEOUT_E2E_MODE_SWITCH" 5 "MCOA mode" \
        adc_not_mco_mode || true
    log_substep "Waiting for MCOA to auto-detect ADC change"
    if ! wait_until 60 5 "ManifestWork auto-generation" mw_has_rs_prometheusrules; then
        log_warn "MCOA did not auto-reconcile after ADC change — restarting as fallback"
        kube_retry $KUBE_CLI rollout restart deployment/$MCOA_DEPLOY -n "$OBS_NAMESPACE" 2>/dev/null || true
        $KUBE_CLI rollout status deployment/$MCOA_DEPLOY \
            -n "$OBS_NAMESPACE" --timeout="${TIMEOUT_ROLLOUT}s" 2>/dev/null || true
        wait_for_reconcile 30 "Waiting for ManifestWork generation"
    fi

    log_substep "Verifying MCOA mode active"
    assert_not_exists policy rs-prom-rules-policy "$GLOBAL_SET_NAMESPACE" || ((errors++)) || true
    assert_exists configmap rs-namespace-config "$OBS_NAMESPACE" || ((errors++)) || true

    log_substep "Checking specHash populated"
    verify_spec_hashes_populated || ((errors++)) || true

    log_substep "Checking ManifestWork PrometheusRules"
    count_mw_prometheusrules || ((errors += MW_PR_ERRORS)) || true
    if [[ $MW_PR_COUNT -eq 0 && $MW_PR_ERRORS -eq 0 ]]; then
        log_error "  ManifestWorks: 0 RS PrometheusRules"
        ((errors++)) || true
    elif [[ $MW_PR_COUNT -gt 0 ]]; then
        log_success "  ManifestWorks: $MW_PR_COUNT RS PrometheusRule(s)"
    fi

    log_substep "Checking ADC state"
    verify_adc_state "enabled" "enabled" || ((errors++)) || true

    verify_perses_dashboards "true" "true" || ((errors++)) || true

    log_substep "Switching back to MCO mode"
    $KUBE_CLI annotate mco "$MCO_NAME" "$RS_ANNOTATION-" --overwrite 2>/dev/null || true

    wait_until "$TIMEOUT_E2E_MODE_SWITCH" 5 "MCO mode restoration" \
        mco_placements_ready || true
    sleep 20
    wait_until 30 5 "placement stabilization" mco_placements_ready || true

    log_substep "Verifying MCO mode restored"
    assert_exists policy rs-prom-rules-policy "$GLOBAL_SET_NAMESPACE" || ((errors++)) || true
    assert_exists policy rs-virt-prom-rules-policy "$GLOBAL_SET_NAMESPACE" || ((errors++)) || true

    CURRENT_MODE="mco"
    log_substep "Checking ADC state"
    verify_adc_state "disabled" "disabled" || ((errors++)) || true

    if [[ $errors -gt 0 ]]; then
        PHASE_FAIL_REASON="ADC not synced to disabled after mode switch"
        return 1
    fi
    return 0
}

# =============================================================================
# Summary
# =============================================================================

print_summary() {
    echo ""
    print_separator
    echo -e "${BOLD}Right-Sizing E2E Results${NC}"
    print_separator

    local cluster_url
    cluster_url=$($KUBE_CLI cluster-info 2>/dev/null | head -1 | awk '{print $NF}' || echo "unknown")
    local mc_count
    mc_count=$($KUBE_CLI get managedcluster --no-headers 2>/dev/null | wc -l | tr -d ' ' || echo "0")
    local mc_details=""
    if [[ "$mc_count" -gt 0 ]]; then
        mc_details=$($KUBE_CLI get managedcluster \
            -o jsonpath='{range .items[*]}{.metadata.name}{"\t"}{.metadata.labels.openshiftVersion}{"\t"}{.status.conditions[?(@.type=="ManagedClusterConditionAvailable")].status}{"\t"}{.spec.managedClusterClientConfigs[0].url}{"\n"}{end}' \
            2>/dev/null || echo "")
    fi
    local acm_version
    acm_version=$($KUBE_CLI get mch multiclusterhub -n "$ACM_NAMESPACE" \
        -o jsonpath='{.status.currentVersion}' 2>/dev/null || echo "unknown")
    local mco_image
    mco_image=$($KUBE_CLI get pod -n "$ACM_NAMESPACE" \
        -l name=multicluster-observability-operator \
        -o jsonpath='{.items[0].spec.containers[0].image}' 2>/dev/null || echo "unknown")
    local mcoa_image=""
    # Priority 1: actual running MCOA addon-manager pod on the cluster
    mcoa_image=$($KUBE_CLI get pod -n "$OBS_NAMESPACE" \
        -l app=multicluster-observability-addon-manager \
        -o jsonpath='{.items[0].spec.containers[0].image}' 2>/dev/null || echo "")
    # Priority 2: mch-image-manifest ConfigMap (ACM source of truth)
    if [[ -z "$mcoa_image" ]]; then
        local manifest_cm
        manifest_cm=$($KUBE_CLI get configmap -n "$ACM_NAMESPACE" --no-headers 2>/dev/null | \
            awk '/^mch-image-manifest/{print $1}' | tail -1)
        if [[ -n "$manifest_cm" ]]; then
            mcoa_image=$($KUBE_CLI get configmap "$manifest_cm" -n "$ACM_NAMESPACE" \
                -o jsonpath='{.data.multicluster_observability_addon}' 2>/dev/null || echo "")
        fi
    fi
    mcoa_image="${mcoa_image:-unknown}"

    local coo_version="$CAPTURED_COO_VERSION"
    local perses_image="$CAPTURED_PERSES_IMAGE"

    echo -e "  Hub Cluster:      $cluster_url"
    echo -e "  ACM Version:      $acm_version"
    if [[ -n "$coo_version" ]]; then
        echo -e "  COO Version:      $coo_version"
    fi
    echo -e "  Managed Clusters: $mc_count"
    if [[ -n "$mc_details" ]]; then
        while IFS=$'\t' read -r mc_name mc_ocp mc_avail mc_url; do
            if [[ -z "$mc_name" ]]; then continue; fi
            local status_str="Available"
            if [[ "$mc_avail" != "True" ]]; then status_str="Unavailable"; fi
            local ocp_str=""
            if [[ -n "$mc_ocp" ]]; then ocp_str="OCP $mc_ocp"; fi
            if [[ "$mc_name" == "local-cluster" ]]; then
                printf "    %-20s %-14s %s\n" "$mc_name" "$status_str" "$ocp_str"
            else
                printf "    %-20s %-14s %-12s %s\n" "$mc_name" "$status_str" "$ocp_str" "${mc_url:-}"
            fi
        done <<< "$mc_details"
    fi
    echo -e "  MCO Image:        $mco_image"
    echo -e "  MCOA Image:       $mcoa_image"
    if [[ -n "$perses_image" ]]; then
        echo -e "  Perses Image:     $perses_image"
    fi
    echo ""

    printf "  ${BOLD}%-6s %-42s %-8s %-8s %s${NC}\n" "ID" "Test" "Result" "Time" "Notes"
    printf "  %-6s %-42s %-8s %-8s %s\n" "----" "----" "------" "----" "-----"

    for i in "${!RESULT_IDS[@]}"; do
        local id="${RESULT_IDS[$i]}"
        local name="${RESULT_NAMES[$i]}"
        local status="${RESULT_STATUSES[$i]}"
        local notes="${RESULT_NOTES[$i]}"
        local duration="${RESULT_DURATIONS[$i]}"

        local color="$NC"
        case "$status" in
            PASS) color="$GREEN" ;;
            FAIL) color="$RED" ;;
            SKIP) color="$YELLOW" ;;
        esac

        local dur_str=""
        if [[ "$status" != "SKIP" || "$duration" -gt 0 ]]; then
            dur_str=$(format_duration "$duration")
        fi

        printf "  %-6s %-42s ${color}%-8s${NC} %-8s %s\n" \
            "$id" "$name" "$status" "$dur_str" "$notes"
    done

    local total_duration=$((SECONDS - E2E_START_TIME))
    local total_dur_str
    total_dur_str=$(format_duration "$total_duration")

    echo ""
    print_separator
    echo -e "  ${GREEN}PASS: $TOTAL_PASS${NC}  ${RED}FAIL: $TOTAL_FAIL${NC}  ${YELLOW}SKIP: $TOTAL_SKIP${NC}  Total: $total_dur_str"
    print_separator

    if [[ $TOTAL_FAIL -gt 0 ]]; then
        echo ""
        log_warn "Some tests failed. Run 'bin/rs-status' for current state."
    fi

    local uninstall_ran=false
    for i in "${!RESULT_IDS[@]}"; do
        if [[ "${RESULT_IDS[$i]}" =~ ^1[345] ]]; then
            if [[ "${RESULT_STATUSES[$i]}" == "PASS" ]]; then
                uninstall_ran=true
            fi
        fi
    done
    if [[ "$uninstall_ran" == "true" ]]; then
        if ! resource_exists mco "$MCO_NAME" 2>/dev/null; then
            echo ""
            log_info "MCO was deleted during tests. Reinstall with:"
            log_info "  bin/setup-observability install"
        fi
    fi
}

# =============================================================================
# Main
# =============================================================================

main() {
    parse_args "$@"

    E2E_START_TIME=$SECONDS

    init_acm_tools
    init_hub_context

    echo ""
    log_step "Right-Sizing E2E Validation"
    print_separator
    if [[ -n "$SELECTED_PHASES" ]]; then
        log_info "Selected phases: $SELECTED_PHASES"
    else
        log_info "Running all phases"
    fi
    if [[ -n "$FORCE_MODE" ]]; then
        log_info "Forced mode: $FORCE_MODE"
    fi

    if [[ -n "$BUILD_TARGET" ]]; then
        prephase_build || { log_error "Build pre-phase failed"; exit 1; }
    elif [[ "$IMAGE_OVERRIDE_ONLY" == "true" ]]; then
        prephase_image_override || { log_error "Image override failed"; exit 1; }
    fi

    # Phase order optimized to minimize mode switches:
    #   Group 1: MCO-mode tests (no switches from baseline)
    #   Group 2: MCO->MCOA transition + MCOA-mode tests (1 switch)
    #   Group 3: MCOA->MCO round-trip tests (3 switches)
    #   Group 4: Destructive tests — MCO deletion/reinstall (last)
    run_phase "0"   "Pre-flight checks"              phase_0
    run_phase "1"   "Baseline resource verification"  phase_1
    run_phase "2a"  "Disable namespace RS only"       phase_2a
    run_phase "2b"  "Swap features (ns on, virt off)" phase_2b
    run_phase "2c"  "Disable both features"           phase_2c
    run_phase "2d"  "Re-enable both features"         phase_2d
    run_phase "2e"  "NamespaceBinding change (MCO)"   phase_2e
    run_phase "3"   "Spoke validation"                phase_3
    run_phase "4"   "ConfigMap propagation (MCO)"     phase_4
    run_phase "4a"  "ConfigMap coexistence (MCO+MCOA)" phase_4a
    run_phase "5"   "MCO -> MCOA switch"              phase_5
    run_phase "6"   "SpecHash freshness"              phase_6
    run_phase "7"   "ConfigMap predicate side-effect"  phase_7
    run_phase "8"   "Placement filter"                phase_8
    run_phase "9a"  "Disable namespace RS (MCOA)"     phase_9a
    run_phase "9b"  "Swap features (MCOA)"            phase_9b
    run_phase "9c"  "Disable both (MCOA)"             phase_9c
    run_phase "9d"  "Re-enable both (MCOA)"           phase_9d
    run_phase "9e"  "NamespaceBinding change (MCOA)"  phase_9e
    run_phase "10"  "ConfigMap propagation (MCOA)"    phase_10
    run_phase "11"  "MCOA -> MCO switch"              phase_11
    run_phase "12"  "Version mismatch"                phase_12
    run_phase "13"  "Uninstall cleanup (MCO mode)"    phase_13
    run_phase "14"  "Uninstall cleanup (MCOA mode)"   phase_14
    run_phase "15"  "MCOA uninstall + reinstall"      phase_15
    run_phase "16"  "Mode switch after reinstall"     phase_16

    print_summary

    [[ $TOTAL_FAIL -eq 0 ]]
}

main "$@"
