#!/bin/bash
# =============================================================================
# rs-mode-switch — Switch right-sizing between MCO (Policy) and MCOA (ManifestWork) modes
# =============================================================================
#
# Usage:
#   rs-mode-switch mcoa           # Switch to MCOA mode (ManifestWork-based)
#   rs-mode-switch mco            # Switch to MCO mode (Policy-based)
#   rs-mode-switch status         # Show current mode and state
#   rs-mode-switch enable         # Enable right-sizing in MCO CR
#   rs-mode-switch disable        # Disable right-sizing in MCO CR
#
# Handles all the coordination automatically:
#   - ADC state sync wait
#   - ConfigMap trigger for faster MCO mode convergence
#   - MCOA addon manager restart after mode switch
#   - COO auto-install wait (MCOA mode)
# =============================================================================

set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/../lib/common.sh"

usage() {
    echo "Usage: $(basename "$0") <command>"
    echo ""
    echo "Commands:"
    echo "  mcoa      Switch to MCOA mode (ManifestWork-based)"
    echo "  mco       Switch to MCO mode (Policy-based)"
    echo "  status    Show current right-sizing mode and state"
    echo "  enable    Enable right-sizing in MCO CR (both namespace + virtualization)"
    echo "  disable   Disable right-sizing in MCO CR"
    echo ""
    echo "Options:"
    echo "  --no-wait     Skip waiting for reconciliation"
    echo "  --ns-only     Enable/disable namespace right-sizing only"
    echo "  --virt-only   Enable/disable virtualization right-sizing only"
}

get_current_mode() {
    local annotation
    annotation=$(get_resource_field mco "$MCO_NAME" "" \
        "{.metadata.annotations.${RS_ANNOTATION//./\\.}}" || echo "")
    if [[ -n "$annotation" ]]; then
        echo "mcoa"
    else
        echo "mco"
    fi
}

get_rs_state() {
    local ns_enabled virt_enabled
    ns_enabled=$(get_resource_field mco "$MCO_NAME" "" \
        '{.spec.capabilities.platform.analytics.namespaceRightSizingRecommendation.enabled}' || echo "")
    virt_enabled=$(get_resource_field mco "$MCO_NAME" "" \
        '{.spec.capabilities.platform.analytics.virtualizationRightSizingRecommendation.enabled}' || echo "")
    echo "${ns_enabled:-unset}:${virt_enabled:-unset}"
}

check_coo_installed() {
    local coo_csv
    coo_csv=$($KUBE_CLI get csv -n openshift-operators --no-headers 2>/dev/null | grep -i cluster-observability-operator || true)
    if [[ -n "$coo_csv" ]]; then
        return 0
    fi
    return 1
}

do_switch_mcoa() {
    local no_wait=false
    [[ "${1:-}" == "--no-wait" ]] && no_wait=true

    local current_mode
    current_mode=$(get_current_mode)
    if [[ "$current_mode" == "mcoa" ]]; then
        log_info "Already in MCOA mode — no change needed"
        do_status
        return 0
    fi

    log_step "Switching to MCOA mode (ManifestWork-based)"

    # Set the annotation on MCO CR
    log_substep "Setting MCO CR annotation: right-sizing-capable=true"
    $KUBE_CLI annotate mco "$MCO_NAME" \
        "$RS_ANNOTATION=true" --overwrite

    if [[ "$no_wait" == "false" ]]; then
        # Wait for MCO to detect annotation, sync ADC, and clean up Policies
        wait_with_message 30 "Waiting for MCO to sync ADC and clean up Policies"

        # Restart addon manager to pick up new ADC state
        log_substep "Restarting MCOA addon manager"
        $KUBE_CLI rollout restart deployment/$MCOA_DEPLOY \
            -n "$OBS_NAMESPACE" 2>/dev/null
        $KUBE_CLI rollout status deployment/$MCOA_DEPLOY \
            -n "$OBS_NAMESPACE" --timeout=120s 2>/dev/null

        wait_with_message 30 "Waiting for ManifestWork reconciliation"

        # Wait for COO to be auto-installed by MCOA
        log_substep "Waiting for COO auto-installation by MCOA"
        local coo_timeout=120
        local coo_installed=false
        for ((i=0; i<coo_timeout; i+=10)); do
            if check_coo_installed; then
                coo_installed=true
                break
            fi
            printf "\r  ${BLUE}Waiting for COO to be installed (%ds/%ds)...${NC}  " "$i" "$coo_timeout"
            sleep 10
        done
        printf "\r%-60s\r" " "

        if [[ "$coo_installed" == "true" ]]; then
            log_success "COO auto-installed by MCOA"

            # Wait for Perses pod to be ready
            log_substep "Waiting for Perses pod"
            local perses_timeout=90
            local perses_ready=false
            local coo_ns="openshift-cluster-observability-operator"
            for ((i=0; i<perses_timeout; i+=10)); do
                local perses_phase
                perses_phase=$($KUBE_CLI get pods -n "$coo_ns" --no-headers 2>/dev/null | grep "^perses-" | awk '{print $3}' | head -1)
                if [[ "$perses_phase" == "Running" ]]; then
                    perses_ready=true
                    break
                fi
                printf "\r  ${BLUE}Waiting for Perses pod (%ds/%ds)...${NC}  " "$i" "$perses_timeout"
                sleep 10
            done
            printf "\r%-60s\r" " "

            if [[ "$perses_ready" == "true" ]]; then
                log_success "Perses pod running"
            else
                log_warn "Perses pod not ready yet — check rs-status later"
            fi
        else
            log_warn "COO not installed after ${coo_timeout}s — MCOA may still be reconciling. Check rs-status later"
        fi
    fi

    echo ""
    log_success "Switched to MCOA mode"
    do_status
}

do_switch_mco() {
    local no_wait=false
    [[ "${1:-}" == "--no-wait" ]] && no_wait=true

    local current_mode
    current_mode=$(get_current_mode)
    if [[ "$current_mode" == "mco" ]]; then
        log_info "Already in MCO mode — no change needed"
        do_status
        return 0
    fi

    log_step "Switching to MCO mode (Policy-based)"

    # Remove the annotation from MCO CR
    log_substep "Removing MCO CR annotation"
    $KUBE_CLI annotate mco "$MCO_NAME" \
        "$RS_ANNOTATION-" --overwrite 2>/dev/null || true

    if [[ "$no_wait" == "false" ]]; then
        # Trigger ConfigMap change to accelerate Policy creation.
        # MCO v77+ has freshEnable detection that creates resources on first reconcile,
        # but the ConfigMap patch fires the predicate sooner for faster convergence.
        log_substep "Triggering ConfigMap change to force Policy creation"
        $KUBE_CLI patch configmap rs-namespace-config \
            -n "$OBS_NAMESPACE" \
            --type=merge \
            -p "{\"data\":{\"mcoTrigger\":\"$(date +%s)\"}}" 2>/dev/null || true
        $KUBE_CLI patch configmap rs-virt-config \
            -n "$OBS_NAMESPACE" \
            --type=merge \
            -p "{\"data\":{\"mcoTrigger\":\"$(date +%s)\"}}" 2>/dev/null || true

        wait_with_message 45 "Waiting for Policy creation and propagation"
    fi

    echo ""
    log_success "Switched to MCO mode"
    do_status
}

do_enable() {
    local ns_flag=true virt_flag=true

    while [[ $# -gt 0 ]]; do
        case "$1" in
            --ns-only)   virt_flag=false; shift ;;
            --virt-only) ns_flag=false; shift ;;
            *) log_error "Unknown option: $1"; usage; exit 1 ;;
        esac
    done

    log_step "Enabling right-sizing (namespace=$ns_flag, virtualization=$virt_flag)"

    $KUBE_CLI patch mco "$MCO_NAME" --type=merge -p "{
        \"spec\": {
            \"capabilities\": {
                \"platform\": {
                    \"analytics\": {
                        \"namespaceRightSizingRecommendation\": {\"enabled\": $ns_flag},
                        \"virtualizationRightSizingRecommendation\": {\"enabled\": $virt_flag}
                    }
                }
            }
        }
    }"

    log_success "Right-sizing enabled in MCO CR"
}

do_disable() {
    log_step "Disabling right-sizing"

    $KUBE_CLI patch mco "$MCO_NAME" --type=merge -p '{
        "spec": {
            "capabilities": {
                "platform": {
                    "analytics": {
                        "namespaceRightSizingRecommendation": {"enabled": false},
                        "virtualizationRightSizingRecommendation": {"enabled": false}
                    }
                }
            }
        }
    }'

    log_success "Right-sizing disabled in MCO CR"
}

do_status() {
    if ! resource_exists mco "$MCO_NAME"; then
        log_step "Right-Sizing Status"
        echo ""
        log_warn "MCO CR not found. Set up observability first:"
        log_info "  bin/setup-observability"
        return 0
    fi

    log_step "Right-Sizing Status"
    echo ""

    # Current mode
    local mode
    mode=$(get_current_mode)
    local annotation
    annotation=$(get_resource_field mco "$MCO_NAME" "" \
        "{.metadata.annotations.${RS_ANNOTATION//./\\.}}" || echo "")

    if [[ "$mode" == "mcoa" ]]; then
        log_success "Mode: MCOA (ManifestWork-based)  [annotation=$annotation]"
    else
        log_info "Mode: MCO (Policy-based)  [annotation=${annotation:-not set}]"
    fi

    # MCO CR state
    local state
    state=$(get_rs_state)
    local ns_state="${state%%:*}"
    local virt_state="${state##*:}"
    local rs_active=false
    [[ "$ns_state" == "true" || "$virt_state" == "true" ]] && rs_active=true

    echo ""
    log_info "MCO CR Right-Sizing:"
    if [[ "$ns_state" == "true" ]]; then
        log_success "  Namespace:      enabled"
    elif [[ "$ns_state" == "false" ]]; then
        log_info "  Namespace:      disabled"
    else
        log_warn "  Namespace:      ${ns_state}"
    fi
    if [[ "$virt_state" == "true" ]]; then
        log_success "  Virtualization: enabled"
    elif [[ "$virt_state" == "false" ]]; then
        log_info "  Virtualization: disabled"
    else
        log_warn "  Virtualization: ${virt_state}"
    fi

    # ADC state (only relevant in MCOA mode)
    if [[ "$mode" == "mcoa" ]]; then
        echo ""
        log_info "AddOnDeploymentConfig:"
        local adc_json
        adc_json=$($KUBE_CLI get addondeploymentconfig "$MCOA_NAME" \
            -n "$OBS_NAMESPACE" -o json 2>/dev/null || echo "{}")
        local ns_adc virt_adc
        ns_adc=$(echo "$adc_json" | jq -r '.spec.customizedVariables[]? | select(.name=="platformNamespaceRightSizing") | .value' 2>/dev/null)
        virt_adc=$(echo "$adc_json" | jq -r '.spec.customizedVariables[]? | select(.name=="platformVirtualizationRightSizing") | .value' 2>/dev/null)
        log_info "  platformNamespaceRightSizing:      ${ns_adc:-not set (auto-enables)}"
        log_info "  platformVirtualizationRightSizing:  ${virt_adc:-not set (auto-enables)}"

        # MCA specHash check
        echo ""
        log_info "ManagedClusterAddon specHash:"
        local mc_specHash_ok=true
        local mc_list
        mc_list=$($KUBE_CLI get managedcluster -o jsonpath='{.items[*].metadata.name}' 2>/dev/null || echo "")
        for mc_name in $mc_list; do
            local spec_hash
            spec_hash=$($KUBE_CLI get managedclusteraddon "$MCOA_NAME" -n "$mc_name" \
                -o jsonpath='{.status.configReferences[0].desiredConfig.specHash}' 2>/dev/null || echo "")
            if [[ -n "$spec_hash" ]]; then
                log_success "  $mc_name: $spec_hash"
            else
                log_error "  $mc_name: EMPTY (MCOA will not create ManifestWorks)"
                mc_specHash_ok=false
            fi
        done
        if [[ "$mc_specHash_ok" == "false" ]]; then
            log_error "  FIX: MCO operator must populate desiredConfig.specHash on MCA"
        fi
    fi

    # Hub resources (not-found is expected when right-sizing is disabled)
    local not_found_log="log_error"
    [[ "$rs_active" == "false" ]] && not_found_log="log_info"

    echo ""
    log_info "Hub Resources:"
    if [[ "$mode" == "mco" ]]; then
        # Policies
        if resource_exists policy rs-prom-rules-policy "$GLOBAL_SET_NAMESPACE"; then
            log_success "  Policy (namespace): exists"
        else
            $not_found_log "  Policy (namespace): not found"
        fi
        if resource_exists policy rs-virt-prom-rules-policy "$GLOBAL_SET_NAMESPACE"; then
            log_success "  Policy (virtualization): exists"
        else
            $not_found_log "  Policy (virtualization): not found"
        fi
    else
        # MCOA placements
        if resource_exists placement rs-placement "$GLOBAL_SET_NAMESPACE"; then
            log_success "  Placement (namespace): exists"
        else
            $not_found_log "  Placement (namespace): not found"
        fi
        if resource_exists placement rs-virt-placement "$GLOBAL_SET_NAMESPACE"; then
            log_success "  Placement (virtualization): exists"
        else
            $not_found_log "  Placement (virtualization): not found"
        fi

        # ManifestWork PrometheusRules per spoke
        local total_pr=0
        local spoke_list
        spoke_list=$($KUBE_CLI get managedcluster -o jsonpath='{.items[*].metadata.name}' 2>/dev/null || echo "")
        log_info "  ManifestWork PrometheusRules:"
        for spoke_name in $spoke_list; do
            local pr_names=""
            for mw in $($KUBE_CLI get manifestwork -n "$spoke_name" -o name 2>/dev/null | grep "$MCOA_MW_PATTERN" || true); do
                local names
                names=$($KUBE_CLI get "$mw" -n "$spoke_name" -o json 2>/dev/null | \
                    jq -r '[.spec.workload.manifests[]? | select(.kind=="PrometheusRule") | select(.metadata.name | test("acm-rs")) | .metadata.name] | .[]' 2>/dev/null || true)
                if [[ -n "$names" ]]; then
                    pr_names="${pr_names:+$pr_names$'\n'}$names"
                fi
            done
            local pr_count=0
            if [[ -n "$pr_names" ]]; then
                pr_count=$(echo "$pr_names" | wc -l | tr -d ' ')
                total_pr=$((total_pr + pr_count))
                log_success "    $spoke_name: $pr_count PrometheusRule(s)"
                echo "$pr_names" | while read -r name; do
                    log_info "      - $name"
                done
            else
                if [[ "$rs_active" == "true" ]]; then
                    log_error "    $spoke_name: 0 PrometheusRules"
                else
                    $not_found_log "    $spoke_name: 0 PrometheusRules"
                fi
            fi
        done
        if [[ "$total_pr" -eq 0 && "$rs_active" == "true" ]]; then
            log_error "  Total: 0 PrometheusRules across all spokes"
        fi
    fi

    # ConfigMaps
    echo ""
    log_info "ConfigMaps:"
    if resource_exists configmap rs-namespace-config "$OBS_NAMESPACE"; then
        log_success "  rs-namespace-config: exists"
    else
        $not_found_log "  rs-namespace-config: not found"
    fi
    if resource_exists configmap rs-virt-config "$OBS_NAMESPACE"; then
        log_success "  rs-virt-config: exists"
    else
        $not_found_log "  rs-virt-config: not found"
    fi

    # COO + Perses (only relevant in MCOA mode with RS active)
    if [[ "$mode" == "mcoa" && "$rs_active" == "true" ]]; then
        echo ""
        log_info "Cluster Observability Operator (COO):"
        local coo_ns="openshift-cluster-observability-operator"
        if check_coo_installed; then
            local coo_phase
            coo_phase=$($KUBE_CLI get csv -n openshift-operators --no-headers 2>/dev/null | grep -i cluster-observability-operator | awk '{print $NF}' || true)
            log_success "  COO: installed (${coo_phase:-unknown})"
        else
            log_error "  COO: not installed (required for Perses dashboards)"
        fi

        # Perses pod
        local perses_phase
        perses_phase=$($KUBE_CLI get pods -n "$coo_ns" --no-headers 2>/dev/null | grep "^perses-" | awk '{print $3}' | head -1)
        if [[ "$perses_phase" == "Running" ]]; then
            log_success "  Perses pod: Running"
        elif [[ -n "$perses_phase" ]]; then
            log_warn "  Perses pod: $perses_phase"
        else
            log_warn "  Perses pod: not found"
        fi

        # Perses dashboards
        local dashboard_count
        dashboard_count=$($KUBE_CLI get persesdashboard -n "$ANALYTICS_NAMESPACE" --no-headers 2>/dev/null | grep -c "acm-rs" || true)
        if [[ "$dashboard_count" -gt 0 ]]; then
            log_success "  Perses dashboards: $dashboard_count"
            $KUBE_CLI get persesdashboard -n "$ANALYTICS_NAMESPACE" --no-headers 2>/dev/null | grep "acm-rs" | awk '{print "    - " $1}'
        else
            log_warn "  Perses dashboards: 0"
        fi

        # UIPlugin
        if $KUBE_CLI get uiplugin monitoring &>/dev/null; then
            log_success "  UIPlugin: monitoring"
        else
            log_warn "  UIPlugin: not found"
        fi
    fi
}

# --- Main ---
case "${1:-}" in
    -h|--help|"") usage; exit 0 ;;
esac

init_acm_tools

# Save and restore original context on exit, then switch to hub
ORIGINAL_CONTEXT=$($KUBE_CLI config current-context 2>/dev/null || echo "")
trap '$KUBE_CLI config use-context "$ORIGINAL_CONTEXT" &>/dev/null 2>&1 || true' EXIT
switch_context "$HUB_CONTEXT" || { log_error "Failed to switch to hub context"; exit 1; }

case "$1" in
    mcoa)    shift; do_switch_mcoa "$@" ;;
    mco)     shift; do_switch_mco "$@" ;;
    enable)  shift; do_enable "$@" ;;
    disable) do_disable ;;
    status)  do_status ;;
    *) log_error "Unknown command: $1"; usage; exit 1 ;;
esac
