#!/bin/bash
# =============================================================================
# rs-status — Quick right-sizing diagnostic dashboard
# =============================================================================
#
# Usage:
#   rs-status                 # Show full status
#   rs-status --hub-only      # Skip spoke checks
#   rs-status --spoke NAME    # Check specific spoke
#   rs-status --watch         # Refresh every 10s
#
# Shows a one-screen color-coded overview of right-sizing state across
# hub and spoke clusters.
# =============================================================================

set -euo pipefail
SCRIPT_DIR="$(cd "$(dirname "${BASH_SOURCE[0]}")" && pwd)"
source "$SCRIPT_DIR/../lib/common.sh"

usage() {
    echo "Usage: $(basename "$0") [options]"
    echo ""
    echo "Options:"
    echo "  --hub-only     Skip spoke cluster checks"
    echo "  --spoke NAME   Spoke context to check (default: $NAMESPACE_SPOKE_CONTEXT)"
    echo "  --watch        Refresh every 10 seconds (Ctrl+C to stop)"
    echo "  --json         Output as JSON (for scripting)"
}

HUB_ONLY=false
SPOKE="$NAMESPACE_SPOKE_CONTEXT"
WATCH_MODE=false
JSON_MODE=false

while [[ $# -gt 0 ]]; do
    case "$1" in
        --hub-only) HUB_ONLY=true; shift ;;
        --spoke)    SPOKE="$2"; shift 2 ;;
        --watch)    WATCH_MODE=true; shift ;;
        --json)     JSON_MODE=true; shift ;;
        -h|--help)  usage; exit 0 ;;
        *) log_error "Unknown option: $1"; usage; exit 1 ;;
    esac
done

show_status() {
    if [[ "$JSON_MODE" == "true" ]]; then
        show_status_json
        return
    fi

    print_separator
    echo -e "${BOLD}Right-Sizing Status Dashboard${NC}"
    print_separator
    echo ""

    # ── Mode ──
    local annotation
    annotation=$($KUBE_CLI get mco "$MCO_NAME" \
        -o jsonpath="{.metadata.annotations.${RS_ANNOTATION//./\\.}}" 2>/dev/null || echo "")

    local mode="MCO (Policy-based)"
    local mode_color="$BLUE"
    if [[ "$annotation" == "v1" ]]; then
        mode="MCOA (ManifestWork-based)"
        mode_color="$GREEN"
    fi
    echo -e "  Mode:  ${mode_color}${BOLD}$mode${NC}"
    echo -e "  MCO CR: annotation=${annotation:-<not set>}"

    # ── MCO CR ──
    echo ""
    echo -e "${BOLD}  MCO CR (spec.capabilities.platform.analytics):${NC}"
    local ns_enabled virt_enabled
    ns_enabled=$($KUBE_CLI get mco "$MCO_NAME" \
        -o jsonpath='{.spec.capabilities.platform.analytics.namespaceRightSizingRecommendation.enabled}' 2>/dev/null || echo "?")
    virt_enabled=$($KUBE_CLI get mco "$MCO_NAME" \
        -o jsonpath='{.spec.capabilities.platform.analytics.virtualizationRightSizingRecommendation.enabled}' 2>/dev/null || echo "?")

    local ns_icon="$RED" virt_icon="$RED"
    [[ "$ns_enabled" == "true" ]] && ns_icon="$GREEN"
    [[ "$virt_enabled" == "true" ]] && virt_icon="$GREEN"
    echo -e "    ${ns_icon}Namespace:       $ns_enabled${NC}"
    echo -e "    ${virt_icon}Virtualization:  $virt_enabled${NC}"

    # ── ADC ──
    echo ""
    echo -e "${BOLD}  AddOnDeploymentConfig:${NC}"
    local adc_json
    adc_json=$($KUBE_CLI get addondeploymentconfig "$MCOA_NAME" \
        -n "$OBS_NAMESPACE" -o json 2>/dev/null || echo "{}")

    local ns_adc virt_adc
    ns_adc=$(echo "$adc_json" | jq -r '.spec.customizedVariables[]? | select(.name=="platformNamespaceRightSizing") | .value' 2>/dev/null)
    virt_adc=$(echo "$adc_json" | jq -r '.spec.customizedVariables[]? | select(.name=="platformVirtualizationRightSizing") | .value' 2>/dev/null)

    local ns_adc_icon="$YELLOW" virt_adc_icon="$YELLOW"
    [[ "$ns_adc" == "enabled" ]] && ns_adc_icon="$GREEN"
    [[ "$ns_adc" == "disabled" ]] && ns_adc_icon="$RED"
    [[ "$virt_adc" == "enabled" ]] && virt_adc_icon="$GREEN"
    [[ "$virt_adc" == "disabled" ]] && virt_adc_icon="$RED"
    echo -e "    ${ns_adc_icon}platformNamespaceRightSizing:      ${ns_adc:-not set (auto-enables)}${NC}"
    echo -e "    ${virt_adc_icon}platformVirtualizationRightSizing: ${virt_adc:-not set (auto-enables)}${NC}"

    # ── ConfigMaps ──
    echo ""
    echo -e "${BOLD}  ConfigMaps (${OBS_NAMESPACE}):${NC}"
    for cm in rs-namespace-config rs-virt-config; do
        if resource_exists configmap "$cm" "$OBS_NAMESPACE"; then
            echo -e "    ${GREEN}$cm: exists${NC}"
        else
            echo -e "    ${RED}$cm: not found${NC}"
        fi
    done

    # ── Mode-specific resources ──
    echo ""
    if [[ "$annotation" == "v1" ]]; then
        # MCOA mode
        echo -e "${BOLD}  MCOA Resources:${NC}"

        # Placements
        for p in rs-placement rs-virt-placement; do
            if resource_exists placement "$p" "$GLOBAL_SET_NAMESPACE"; then
                local decision_count
                decision_count=$($KUBE_CLI get placementdecision -n "$GLOBAL_SET_NAMESPACE" \
                    -l "cluster.open-cluster-management.io/placement=$p" \
                    -o json 2>/dev/null | jq '[.items[]?.status.decisions[]?] | length' 2>/dev/null || echo 0)
                echo -e "    ${GREEN}$p: exists ($decision_count clusters)${NC}"
            else
                echo -e "    ${RED}$p: not found${NC}"
            fi
        done

        # ManifestWorks
        echo ""
        echo -e "${BOLD}  ManifestWork PrometheusRules:${NC}"
        local spoke_list
        spoke_list=$($KUBE_CLI get managedcluster -o jsonpath='{.items[*].metadata.name}' 2>/dev/null)
        for spoke_name in $spoke_list; do
            local pr_names=""
            for mw in $($KUBE_CLI get manifestwork -n "$spoke_name" -o name 2>/dev/null | grep "$MCOA_MW_PATTERN" || true); do
                local names
                names=$($KUBE_CLI get "$mw" -n "$spoke_name" -o json 2>/dev/null | \
                    jq -r '[.spec.workload.manifests[]? | select(.kind=="PrometheusRule") | select(.metadata.name | test("acm-rs")) | .metadata.name] | .[]' 2>/dev/null || true)
                if [[ -n "$names" ]]; then
                    pr_names="${pr_names:+$pr_names$'\n'}$names"
                fi
            done
            if [[ -n "$pr_names" ]]; then
                local pr_count
                pr_count=$(echo "$pr_names" | wc -l | tr -d ' ')
                echo -e "    ${GREEN}$spoke_name: $pr_count PrometheusRule(s)${NC}"
                echo "$pr_names" | while read -r name; do
                    echo -e "      ${GREEN}- $name${NC}"
                done
            else
                echo -e "    ${RED}$spoke_name: 0 PrometheusRules${NC}"
            fi
        done
    else
        # MCO mode
        echo -e "${BOLD}  MCO Policy Resources (${GLOBAL_SET_NAMESPACE}):${NC}"
        for res_type_name in "policy:rs-prom-rules-policy" "policy:rs-virt-prom-rules-policy" "placement:rs-placement" "placement:rs-virt-placement" "placementbinding:rs-policyset-binding" "placementbinding:rs-virt-policyset-binding"; do
            local rtype="${res_type_name%%:*}"
            local rname="${res_type_name##*:}"
            if resource_exists "$rtype" "$rname" "$GLOBAL_SET_NAMESPACE"; then
                echo -e "    ${GREEN}$rtype/$rname: exists${NC}"
            else
                echo -e "    ${RED}$rtype/$rname: not found${NC}"
            fi
        done
    fi

    # ── Spoke PrometheusRules ──
    if [[ "$HUB_ONLY" == "false" ]]; then
        echo ""
        echo -e "${BOLD}  Spoke PrometheusRules:${NC}"

        # Map managed cluster names to kubeconfig contexts
        mc_to_context() {
            case "$1" in
                local-cluster)   echo "$HUB_CONTEXT" ;;
                namespace-spoke) echo "$NAMESPACE_SPOKE_CONTEXT" ;;
                vm-spoke)        echo "$VM_SPOKE_CONTEXT" ;;
                *)               echo "$1" ;;
            esac
        }

        local mc_list checked_contexts=""
        mc_list=$($KUBE_CLI get managedcluster -o jsonpath='{.items[*].metadata.name}' 2>/dev/null || echo "")
        for mc in $mc_list; do
            local ctx
            ctx=$(mc_to_context "$mc")
            # Skip if we already checked this context (e.g. vm-spoke defaults to hub)
            if echo "$checked_contexts" | grep -qw "$ctx"; then
                continue
            fi
            checked_contexts="$checked_contexts $ctx"

            if switch_context "$ctx" 2>/dev/null; then
                local rules
                rules=$($KUBE_CLI get prometheusrule -n openshift-monitoring --no-headers 2>/dev/null | grep -i "rs-\|acm-rs" || true)
                if [[ -n "$rules" ]]; then
                    echo -e "    ${GREEN}$mc ($ctx):${NC}"
                    echo "$rules" | while read -r line; do
                        local name
                        name=$(echo "$line" | awk '{print $1}')
                        echo -e "      ${GREEN}- $name${NC}"
                    done
                else
                    echo -e "    ${RED}$mc ($ctx): no right-sizing PrometheusRules${NC}"
                fi
            else
                echo -e "    ${RED}$mc ($ctx): could not connect${NC}"
            fi
        done
        switch_context "$HUB_CONTEXT" &>/dev/null || true
    fi

    # ── Operator Pods ──
    echo ""
    echo -e "${BOLD}  Operator Pods:${NC}"
    local mco_pod_status mco_pod_phase
    mco_pod_status=$($KUBE_CLI get pods -n "$ACM_NAMESPACE" -l name=multicluster-observability-operator --no-headers 2>/dev/null | awk '{printf "%s (%s)", $1, $3}' | head -1)
    mco_pod_phase=$($KUBE_CLI get pods -n "$ACM_NAMESPACE" -l name=multicluster-observability-operator --no-headers 2>/dev/null | awk '{print $3}' | head -1)
    if [[ "$mco_pod_phase" == "Running" ]]; then
        echo -e "    ${GREEN}MCO:  $mco_pod_status${NC}"
    elif [[ -n "$mco_pod_status" ]]; then
        echo -e "    ${RED}MCO:  $mco_pod_status${NC}"
    else
        echo -e "    ${RED}MCO:  not found${NC}"
    fi

    local mcoa_pod_status
    mcoa_pod_status=$($KUBE_CLI get pods -n "$OBS_NAMESPACE" -l app=$MCOA_DEPLOY --no-headers 2>/dev/null | awk '{printf "%s (%s)", $1, $3}' | head -1)

    # Check if MCOA pod state is correct for the current mode
    local mcoa_has_other_caps=false
    local mco_caps
    mco_caps=$($KUBE_CLI get mco "$MCO_NAME" -o json 2>/dev/null || echo "{}")
    # Check if any non-RS MCOA capability is enabled
    for cap_path in \
        '.spec.capabilities.platform.logs.collection.enabled' \
        '.spec.capabilities.platform.metrics.default.enabled' \
        '.spec.capabilities.platform.analytics.incidentDetection.enabled' \
        '.spec.capabilities.userWorkloads.logs.collection.clusterLogForwarder.enabled' \
        '.spec.capabilities.userWorkloads.traces.collection.collector.enabled' \
        '.spec.capabilities.userWorkloads.traces.collection.instrumentation.enabled' \
        '.spec.capabilities.userWorkloads.metrics.default.enabled'; do
        local val
        val=$(echo "$mco_caps" | jq -r "$cap_path // false" 2>/dev/null)
        if [[ "$val" == "true" ]]; then
            mcoa_has_other_caps=true
            break
        fi
    done

    if [[ "$annotation" == "v1" ]] || [[ "$mcoa_has_other_caps" == "true" ]]; then
        # MCOA should be running
        if [[ -n "$mcoa_pod_status" ]]; then
            echo -e "    ${GREEN}MCOA: $mcoa_pod_status${NC}"
        else
            echo -e "    ${RED}MCOA: not found (EXPECTED to be running)${NC}"
        fi
    else
        # MCOA should NOT be running (MCO-only mode for right-sizing)
        if [[ -n "$mcoa_pod_status" ]]; then
            echo -e "    ${YELLOW}MCOA: $mcoa_pod_status (unexpected — no MCOA capabilities or delegation active)${NC}"
        else
            echo -e "    ${GREEN}MCOA: not running (correct — MCO mode, no MCOA capabilities)${NC}"
        fi
    fi

    # ── COO + Perses ──
    if [[ "$annotation" == "v1" ]]; then
        local coo_ns="openshift-cluster-observability-operator"
        echo ""
        echo -e "${BOLD}  Cluster Observability Operator (COO):${NC}"
        local coo_csv
        coo_csv=$($KUBE_CLI get csv -n openshift-operators --no-headers 2>/dev/null | grep -i cluster-observability-operator || true)
        if [[ -n "$coo_csv" ]]; then
            local coo_phase
            coo_phase=$(echo "$coo_csv" | awk '{print $NF}')
            echo -e "    ${GREEN}COO: installed ($coo_phase)${NC}"
        else
            echo -e "    ${RED}COO: not installed (required for Perses dashboards)${NC}"
        fi

        # Perses pod
        local perses_phase
        perses_phase=$($KUBE_CLI get pods -n "$coo_ns" --no-headers 2>/dev/null | grep "^perses-" | awk '{print $3}' | head -1)
        if [[ "$perses_phase" == "Running" ]]; then
            echo -e "    ${GREEN}Perses pod: Running${NC}"
        elif [[ -n "$perses_phase" ]]; then
            echo -e "    ${YELLOW}Perses pod: $perses_phase${NC}"
        else
            echo -e "    ${RED}Perses pod: not found${NC}"
        fi

        # Perses dashboards
        local dashboard_count
        dashboard_count=$($KUBE_CLI get persesdashboard -n "$ANALYTICS_NAMESPACE" --no-headers 2>/dev/null | grep -c "acm-rs" || echo 0)
        if [[ "$dashboard_count" -gt 0 ]]; then
            echo -e "    ${GREEN}Perses dashboards: $dashboard_count${NC}"
            $KUBE_CLI get persesdashboard -n "$ANALYTICS_NAMESPACE" --no-headers 2>/dev/null | grep "acm-rs" | awk -v g="$GREEN" -v nc="$NC" '{print "      - " g $1 nc}'
        else
            echo -e "    ${RED}Perses dashboards: 0${NC}"
        fi

        # UIPlugin
        if $KUBE_CLI get uiplugin monitoring &>/dev/null; then
            echo -e "    ${GREEN}UIPlugin: monitoring${NC}"
        else
            echo -e "    ${RED}UIPlugin: not found${NC}"
        fi
    fi

    # ── Images ──
    echo ""
    echo -e "${BOLD}  Images:${NC}"
    local mco_img mcoa_img
    mco_img=$(get_resource_field deployment multicluster-observability-operator "$ACM_NAMESPACE" '{.spec.template.spec.containers[0].image}' 2>/dev/null || echo "")
    mcoa_img=$(get_resource_field deployment $MCOA_DEPLOY "$OBS_NAMESPACE" '{.spec.template.spec.containers[0].image}' 2>/dev/null || echo "")
    echo "    MCO:  ${mco_img:-not deployed}"
    echo "    MCOA: ${mcoa_img:-not deployed}"

    echo ""
    print_separator
}

show_status_json() {
    local annotation ns_enabled virt_enabled ns_adc virt_adc

    annotation=$($KUBE_CLI get mco "$MCO_NAME" \
        -o jsonpath="{.metadata.annotations.${RS_ANNOTATION//./\\.}}" 2>/dev/null || echo "")
    ns_enabled=$($KUBE_CLI get mco "$MCO_NAME" \
        -o jsonpath='{.spec.capabilities.platform.analytics.namespaceRightSizingRecommendation.enabled}' 2>/dev/null || echo "null")
    virt_enabled=$($KUBE_CLI get mco "$MCO_NAME" \
        -o jsonpath='{.spec.capabilities.platform.analytics.virtualizationRightSizingRecommendation.enabled}' 2>/dev/null || echo "null")

    local adc_json
    adc_json=$($KUBE_CLI get addondeploymentconfig "$MCOA_NAME" -n "$OBS_NAMESPACE" -o json 2>/dev/null || echo "{}")
    ns_adc=$(echo "$adc_json" | jq -r '.spec.customizedVariables[]? | select(.name=="platformNamespaceRightSizing") | .value' 2>/dev/null || echo "null")
    virt_adc=$(echo "$adc_json" | jq -r '.spec.customizedVariables[]? | select(.name=="platformVirtualizationRightSizing") | .value' 2>/dev/null || echo "null")

    local mode="mco"
    [[ "$annotation" == "v1" ]] && mode="mcoa"

    jq -n \
        --arg mode "$mode" \
        --arg annotation "$annotation" \
        --arg ns_enabled "$ns_enabled" \
        --arg virt_enabled "$virt_enabled" \
        --arg ns_adc "${ns_adc:-null}" \
        --arg virt_adc "${virt_adc:-null}" \
        '{
            mode: $mode,
            annotation: $annotation,
            mco_cr: {
                namespace_enabled: ($ns_enabled == "true"),
                virtualization_enabled: ($virt_enabled == "true")
            },
            adc: {
                namespace: (if $ns_adc == "null" then null else $ns_adc end),
                virtualization: (if $virt_adc == "null" then null else $virt_adc end)
            }
        }'
}

# --- Main ---
if [[ "${1:-}" == "-h" || "${1:-}" == "--help" ]]; then
    usage
    exit 0
fi

init_acm_tools

# Save current context and restore on exit (in case script is interrupted
# while connected to a spoke cluster)
ORIGINAL_CONTEXT=$($KUBE_CLI config current-context 2>/dev/null || echo "")
if [[ -n "$ORIGINAL_CONTEXT" ]]; then
    trap '$KUBE_CLI config use-context "$ORIGINAL_CONTEXT" &>/dev/null' EXIT
fi

if [[ "$WATCH_MODE" == "true" ]]; then
    while true; do
        clear
        show_status
        echo ""
        echo -e "${BLUE}Refreshing every 10s... (Ctrl+C to stop)${NC}"
        sleep 10
    done
else
    show_status
fi
